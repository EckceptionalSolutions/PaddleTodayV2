{
  "name": "canoe-adventures-v2",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "api": "tsx src/server/api-server.ts --port 4322",
    "api:watch": "tsx watch src/server/api-server.ts --port 4322",
    "deps:graph": "node scripts/madge.mjs",
    "deps:unused": "node scripts/knip.mjs",
    "deps:check": "npm run deps:graph && npm run deps:unused",
    "dev": "astro dev",
    "typecheck": "node scripts/typecheck.mjs",
    "typecheck:routes": "tsc --noEmit -p tsconfig.route-data.json",
    "routes:audit": "tsx scripts/audit-route-data.ts",
    "routes:audit:coordinates": "tsx scripts/audit-route-coordinate-river-distance.ts",
    "routes:audit:overlap": "tsx scripts/audit-route-overlap.ts",
    "routes:leads:gather": "tsx scripts/gather-route-leads.ts",
    "routes:safety:audit": "tsx scripts/audit-route-safety.ts",
    "alert:mock-email": "tsx scripts/send-mock-river-alert.ts",
    "alert:mock-push": "tsx scripts/send-mock-river-push.ts",
    "build": "npm run typecheck && astro build",
    "preview": "npm run build && npm run serve",
    "preview:local": "npm run build && npm run serve:local",
    "serve": "tsx src/server/api-server.ts --static dist --port 4321",
    "serve:local": "tsx src/server/api-server.ts --static dist --port 4323",
    "history:snapshot": "tsx src/server/history-snapshot.ts",
    "snapshots:refresh": "tsx src/server/river-snapshot.ts",
    "alerts:evaluate": "tsx src/server/alerts-evaluate.ts",
    "start": "tsx src/server/api-server.ts --static dist",
    "test": "npm run typecheck && vitest run",
    "mobile:start": "npm run start --workspace @paddletoday/mobile",
    "mobile:android": "npm run android --workspace @paddletoday/mobile",
    "mobile:ios": "npm run ios --workspace @paddletoday/mobile",
    "mobile:typecheck": "npm run typecheck --workspace @paddletoday/mobile",
    "mobile:api-smoke": "node scripts/mobile-api-smoke.mjs",
    "cloudflare:traffic": "node scripts/cloudflare-traffic-summary.mjs",
    "metrics:daily": "tsx scripts/daily-site-metrics.ts",
    "mobile:generate-icons": "node scripts/generate-mobile-icons.mjs",
    "mobile:release-check": "node scripts/mobile-release-check.mjs",
    "mobile:eas:whoami": "npm run eas --workspace @paddletoday/mobile -- whoami",
    "mobile:ios:testflight": "npm run ios:testflight --workspace @paddletoday/mobile"
  },
  "dependencies": {
    "@azure/communication-email": "^1.1.0",
    "astro": "^7.0.9",
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "@astrojs/sitemap": "^3.7.3",
    "@playwright/test": "^1.59.1",
    "eas-cli": "^18.13.0",
    "sharp": "^0.34.5",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2"
  },
  "description": "`canoe-adventures-v2` is the new codebase for a reset version of Paddle Today.",
  "main": "index.js",
  "directories": {
    "doc": "docs",
    "test": "tests"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/EckceptionalSolutions/PaddleTodayV2.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/EckceptionalSolutions/PaddleTodayV2/issues"
  },
  "homepage": "https://github.com/EckceptionalSolutions/PaddleTodayV2#readme"
}
