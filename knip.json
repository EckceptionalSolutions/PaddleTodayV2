{
  "ignoreDependencies": [
    "astro"
  ],
  "workspaces": {
    ".": {
      "ignoreDependencies": [
        "@paddletoday/api-contract"
      ],
      "entry": [
        "astro.config.mjs",
        "vitest.config.ts",
        "scripts/**/*.{mjs,ts}",
        "src/**/*.astro",
        "src/scripts/**/*.{js,mjs}",
        "src/server/**/*.ts"
      ],
      "project": [
        "astro.config.mjs",
        "vitest.config.ts",
        "scripts/**/*.{mjs,ts}",
        "src/**/*.astro",
        "src/**/*.{js,mjs,ts,tsx}"
      ]
    },
    "apps/mobile": {
      "ignoreDependencies": [
        "@expo/vector-icons",
        "@expo/ngrok",
        "@paddletoday/api-client",
        "@paddletoday/api-contract",
        "@react-native-firebase/analytics",
        "@react-native-firebase/app",
        "@react-native-firebase/crashlytics",
        "@react-native-async-storage/async-storage",
        "@react-navigation/native",
        "@sentry/react-native",
        "@tanstack/query-async-storage-persister",
        "@tanstack/react-query",
        "@tanstack/react-query-persist-client",
        "expo-image-manipulator",
        "expo-image-picker",
        "expo-location",
        "expo-notifications",
        "expo-status-bar",
        "expo-build-properties",
        "expo-dev-client",
        "react-native-maps",
        "react-native-worklets"
      ],
      "entry": [
        "app.config.js",
        "app.json",
        "app/**/*.{js,jsx,ts,tsx}"
      ],
      "project": [
        "app.config.js",
        "app.json",
        "app/**/*.{js,jsx,ts,tsx}",
        "src/**/*.{js,jsx,ts,tsx}",
        "expo-env.d.ts"
      ]
    },
    "packages/api-client": {
      "entry": [
        "src/index.ts",
        "vitest.config.ts"
      ],
      "project": [
        "src/**/*.{ts,tsx}",
        "vitest.config.ts"
      ]
    },
    "packages/api-contract": {
      "entry": [
        "src/index.ts"
      ],
      "project": [
        "src/**/*.{ts,tsx}"
      ]
    }
  }
}
