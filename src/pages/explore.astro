---
import BaseLayout from '../layouts/BaseLayout.astro';
import FeatureIcon from '../components/FeatureIcon.astro';
import SummaryMapPanel from '../components/SummaryMapPanel.astro';
import RouteBoardCardTemplate from '../components/RouteBoardCardTemplate.astro';
import { listRiverGroups, listRivers } from '../lib/rivers';

const rivers = listRivers();
const riverGroups = listRiverGroups();
const states = [...new Set(rivers.map((river) => river.state))].sort();
const trackedRouteCount = rivers.length;
const trackedRiverCount = riverGroups.length;
---

<BaseLayout
  title="Browse Paddle Results | Paddle Today"
  description="Browse tracked paddle rivers and routes with map-first comparison, live scores, and deeper filters."
>
  <section class="decision-section decision-section--explore explore-page" id="explore">
    <div class="section-head section-head--stacked">
      <div>
        <p class="eyebrow">Explore</p>
        <h1 class="section-title">Browse all paddle results</h1>
      </div>
      <div class="hero__meta">
        <span class="stat-chip">{trackedRiverCount} tracked rivers</span>
        <span class="stat-chip">{trackedRouteCount} tracked routes</span>
      </div>
    </div>

    <div class="decision-section__body" data-explore-content>
      <section class="status-banner status-banner--offline status-banner--hidden" data-board-fetch-banner aria-live="polite">
        <div class="status-banner__eyebrow">Refresh failed</div>
        <div class="status-banner__body">
          <strong data-board-fetch-title>River scores could not be refreshed.</strong>
          <p class="muted" data-board-fetch-detail>The board may be stale. Retry before you drive.</p>
        </div>
      </section>

      <section class="status-banner status-banner--loading status-banner--hidden" data-board-status-banner aria-live="polite" hidden>
        <div class="status-banner__eyebrow">Live read status</div>
        <div class="status-banner__body">
          <strong data-board-banner-title>Checking live reads.</strong>
          <p class="muted" data-board-banner-detail>Pulling the latest gauge and weather data.</p>
        </div>
      </section>

      <section class="explore-workspace" aria-labelledby="explore-workspace-heading">
        <h2 class="sr-only" id="explore-workspace-heading">Explore workspace</h2>

        <section class="board-filters board-filters--full board-filters--embedded" aria-label="Explore workspace controls">
          <div class="board-filters__workspace">
            <section class="board-filters__group board-filters__group--location" aria-labelledby="explore-location-heading">
              <div class="board-filters__group-head">
                <h3 class="board-filters__group-title" id="explore-location-heading">Set your location</h3>
              </div>

              <section class="home-location-bar home-location-bar--explore home-location-bar--embedded" aria-label="Set your location" data-nearby-location-panel>
                <form class="location-panel__form home-location-bar__form" data-location-form>
                  <button class="river-link river-link--inline home-location-bar__use" type="button" data-location-use aria-label="Use my location">
                    <FeatureIcon name="crosshair" size={17} />
                  </button>
                  <label class="filter-search location-panel__search home-location-bar__search">
                    <span class="sr-only">Enter a city or ZIP code</span>
                    <input
                      class="filter-search__input home-location-bar__search-input"
                      type="search"
                      placeholder="City or ZIP code"
                      data-location-input
                    />
                  </label>
                  <div class="location-panel__actions home-location-bar__actions">
                    <button class="filter-chip filter-chip--subtle home-location-bar__search-button" type="submit">
                      Search
                    </button>
                    <button class="filter-chip home-location-bar__clear" type="button" data-location-clear hidden>Clear</button>
                  </div>
                </form>
                <p class="sr-only" data-home-location-summary>Set your location</p>
                <p class="sr-only" data-home-location-sort-summary hidden>Choose a location to compare nearby routes.</p>
              </section>
            </section>

            <section class="board-filters__group board-filters__group--controls" aria-labelledby="explore-controls-heading">
              <div class="board-filters__group-head">
                <h3 class="board-filters__group-title" id="explore-controls-heading">Filters</h3>
              </div>

              <div class="board-filters__controls">
                <label class="filter-select filter-select--sort">
                  <span class="sr-only">Sort the board</span>
                  <select class="filter-select__input" data-sort-select>
                    <option value="best-now">Top picks today</option>
                    <option value="near-you">Best by drive time</option>
                    <option value="nearest">Closest first</option>
                    <option value="highest-confidence">Highest data confidence</option>
                    <option value="lowest-risk">Lowest-risk first</option>
                    <option value="a-z">A-Z</option>
                  </select>
                </label>
                <span class="location-indicator" data-location-indicator hidden aria-live="polite">
                  <span class="location-indicator__spinner" aria-hidden="true"></span>
                  <span data-location-indicator-label>Finding nearest picks...</span>
                </span>
                <label class="filter-search">
                    <span class="sr-only">Search results</span>
                    <input class="filter-search__input" type="search" placeholder="Search a river or route" data-filter-search />
                </label>
                <label class="filter-select">
                  <span class="sr-only">Filter by state</span>
                  <select class="filter-select__input" data-filter-state>
                    <option value="">All states</option>
                    {states.map((state) => <option value={state}>{state}</option>)}
                  </select>
                </label>
                <label class="filter-select">
                  <span class="sr-only">Filter by difficulty</span>
                  <select class="filter-select__input" data-filter-difficulty>
                    <option value="">Any difficulty</option>
                    <option value="easy">Easy</option>
                    <option value="moderate">Moderate</option>
                    <option value="hard">Hard</option>
                  </select>
                </label>
                <label class="filter-select">
                  <span class="sr-only">Filter by whitewater routes</span>
                  <select class="filter-select__input" data-filter-route-type>
                    <option value="non-whitewater" selected>Non-whitewater routes</option>
                    <option value="whitewater">Whitewater only</option>
                    <option value="all">All route types</option>
                  </select>
                </label>
                <label class="filter-select">
                  <span class="sr-only">Filter by drive distance</span>
                  <select class="filter-select__input" data-filter-distance>
                    <option value="">Any drive distance</option>
                    <option value="25">Within 25 miles</option>
                    <option value="50">Within 50 miles</option>
                    <option value="75">Within 75 miles</option>
                    <option value="100">Within 100 miles</option>
                    <option value="150">Within 150 miles</option>
                    <option value="200">Within 200 miles</option>
                  </select>
                </label>
                <label class="filter-select">
                  <span class="sr-only">Filter by paddle time</span>
                  <select class="filter-select__input" data-filter-paddle-time>
                    <option value="">Any paddle time</option>
                    <option value="up-to-3">Under 3 hr</option>
                    <option value="3-to-5">3-5 hr</option>
                    <option value="5-to-7">5-7 hr</option>
                    <option value="7-plus">7+ hr</option>
                  </select>
                </label>
                <label class="filter-select">
                  <span class="sr-only">Filter by Paddle Today Score</span>
                  <select class="filter-select__input" data-filter-rating>
                    <option value="">Paddle Today Score</option>
                    <option value="Strong">Strong only</option>
                    <option value="Good">Good only</option>
                    <option value="Fair">Fair: tradeoffs</option>
                    <option value="No-go">No-go only</option>
                  </select>
                </label>
              </div>

              <div class="board-filters__actions">
                <button class="filter-chip filter-chip--quiet" type="button" data-explore-reset>Reset all filters</button>
                <button class="filter-chip filter-chip--quiet" type="button" data-board-refresh>Refresh board</button>
              </div>
            </section>
          </div>
        </section>

        <div class="explore-workspace__filters" data-filter-pills aria-live="polite"></div>

        <div class="explore-workspace__body">
          <SummaryMapPanel
            id="explore-map"
            mode="explore"
            className="summary-map-shell--explore-workspace"
            mobileLayout="list-map"
            eyebrow="Map view"
            title="Result map"
            lede="Use the map to scan the board, then compare the ranked results."
            showResults={true}
            resultsTitle="Ranked results"
            note="Loading results."
            status="Loading map."
            ariaLabel="Paddle results map"
            itemNounSingular="result"
            itemNounPlural="results"
          />

          <div class="explore-workspace__board">
            <div class="explore-workspace__list-head">
              <div class="explore-workspace__list-head-row">
                <p class="eyebrow">Ranked results</p>
                <span class="explore-workspace__count" data-explore-results-count aria-live="polite">Loading results</span>
              </div>
              <p class="muted explore-workspace__list-note">Click a marker or a result to compare both views together.</p>
            </div>
            <div class="explore-grid-shell" data-explore-shell>
              <div class="river-grid river-grid--explore-list" aria-label="Explore paddle results today" data-explore-grid></div>
            </div>

            <div class="explore-pagination" data-explore-pagination hidden>
              <p class="muted explore-pagination__summary" data-explore-pagination-summary>Showing 1-12 of 12 results</p>
              <div class="explore-pagination__controls">
                <button class="filter-chip" type="button" data-explore-prev>Previous</button>
                <span class="explore-pagination__page" data-explore-page>Page 1 of 1</span>
                <button class="filter-chip" type="button" data-explore-next>Next</button>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="home-board-inline home-board-inline--wide" aria-label="Route requests">
        <p class="home-board-inline__copy">Don&apos;t see a route you paddle?</p>
        <a class="river-link river-link--inline river-link--ghost" href="/request-river/">Request a route</a>
      </section>
    </div>
  </section>

  <RouteBoardCardTemplate />

  <script>
    import '../scripts/explore-page.js';
  </script>
</BaseLayout>
