---
import BaseLayout from '../layouts/BaseLayout.astro';
import RouteBoardCardTemplate from '../components/RouteBoardCardTemplate.astro';

const siteUrl = Astro.site?.href ?? 'https://paddletoday.com/';
const weekendUrl = new URL('/weekend/', siteUrl).href;
const organizationId = new URL('/#organization', siteUrl).href;
const websiteId = new URL('/#website', siteUrl).href;
const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    '@id': `${weekendUrl}#collection`,
    name: 'Best Picks This Weekend',
    description: 'Plan ahead with Paddle Today weekend river picks built from current river shape and the latest forecast confidence.',
    url: weekendUrl,
    isPartOf: {
      '@id': websiteId,
    },
    about: {
      '@id': organizationId,
    },
  },
];
---

<BaseLayout
  title="Paddle Today | Best Picks This Weekend"
  description="Plan ahead with Paddle Today weekend river picks built from current river shape and the latest forecast confidence."
  structuredData={structuredData}
>
  <section class="decision-hero hero weekend-hero">
    <div class="decision-hero__intro">
      <p class="hero__kicker">Weekend planning</p>
      <h1>Best picks this weekend</h1>
      <p class="hero__dates" data-weekend-dates>
        Saturday and Sunday dates are loading.
      </p>
      <p class="hero__lede">
        Early read from current river shape and the weekend forecast. Forecasts can still shift before launch day.
      </p>
      <p class="hero__snapshot" data-weekend-snapshot>
        Checking weekend outlooks...
      </p>
    </div>

    <aside class="hero-call decision-hero__featured weekend-hero__featured" aria-live="polite">
      <p class="eyebrow" data-weekend-featured-label>Top weekend pick</p>
      <p class="hero-call__state" data-weekend-featured-state>Loading weekend read.</p>
      <h2 class="hero-call__title" data-weekend-featured-name>Checking the board</h2>
      <p class="hero-call__reach" data-weekend-featured-reach>Weekend forecast confidence is loading.</p>
      <p class="hero-call__verdict" data-weekend-featured-verdict>Checking outlook</p>

      <div class="hero-call__scoreline">
        <div class="score-orb score-orb--featured" aria-label="Weekend score">
          <span class="score-orb__score" data-weekend-featured-score>--</span>
          <span class="score-orb__rating" data-weekend-featured-rating>Loading</span>
        </div>

        <div class="hero-call__score-meta">
          <div class="hero-call__meta">
            <span class="pill" data-weekend-featured-confidence>Forecast confidence loading</span>
            <span class="pill" data-weekend-featured-current>Today loading</span>
          </div>
        </div>
      </div>

      <p class="hero-call__reason" data-weekend-featured-reason>Loading summary</p>
      <p class="hero-call__signal-line" data-weekend-featured-signal>Loading forecast signals</p>
      <ul class="hero-call__reasons" data-weekend-featured-reasons></ul>

      <p class="hero-call__summary muted" data-weekend-featured-explanation>
        Pulling the strongest weekend pick from the latest stored snapshot.
      </p>
      <button class="hero-call__toggle" type="button" data-weekend-featured-toggle hidden aria-expanded="false">
        Details
      </button>

      <div class="decision-hero__actions">
        <a class="river-link river-link--inline" href="/" data-weekend-featured-link>View route</a>
      </div>
    </aside>

    <div class="decision-hero__support">
      <p class="hero__overview-label">Weekend overview</p>
      <ul class="hero__call-mix" data-weekend-call-mix>
        <li class="hero__call-mix-item hero__call-mix-item--good">
          <strong data-weekend-strong-count>--</strong>
          <span>Strong</span>
        </li>
        <li class="hero__call-mix-item hero__call-mix-item--mixed">
          <strong data-weekend-good-count>--</strong>
          <span>Good</span>
        </li>
        <li class="hero__call-mix-item hero__call-mix-item--mixed">
          <strong data-weekend-fair-count>--</strong>
          <span>Fair: tradeoffs</span>
        </li>
        <li class="hero__call-mix-item hero__call-mix-item--no-go">
          <strong data-weekend-withheld-count>--</strong>
          <span>Not enough data</span>
        </li>
      </ul>
      <p class="hero__project-label">Planning note</p>
      <p class="hero__note muted">
        Weekend picks stay conservative. If the current read or forecast still looks shaky, it stays out of the shortlist.
      </p>
    </div>
  </section>

  <section class="decision-section decision-section--recommended weekend-page__section">
    <div class="section-head section-head--stacked">
      <div>
        <p class="eyebrow">Weekend shortlist</p>
        <h2 class="section-title">Top weekend picks</h2>
      </div>
      <p class="muted section-head__note">
        Use this as a planning read for Saturday and Sunday, then check the live board again before you drive.
      </p>
    </div>

    <div class="recommendation-grid weekend-page__grid" data-weekend-grid></div>
    <div class="weekend-empty-state decision-section__empty" data-weekend-empty hidden>
      <p class="weekend-empty-state__title" data-weekend-empty-title>No reliable weekend picks yet</p>
      <p class="muted weekend-empty-state__copy" data-weekend-empty-copy>
        Forecast confidence is still too low to make weekend calls.
      </p>
    </div>
  </section>

  <section class="decision-section weekend-page__section" data-weekend-watch-section hidden>
    <div class="section-head section-head--stacked">
      <div>
        <p class="eyebrow">Fair: tradeoffs</p>
        <h2 class="section-title">Re-check if the forecast improves</h2>
      </div>
      <p class="muted section-head__note">
        These routes may be paddleable if the forecast improves.
      </p>
    </div>

    <div class="recommendation-grid weekend-page__grid" data-weekend-watch-grid></div>
  </section>

  <RouteBoardCardTemplate />

  <script>
    import '../scripts/weekend-page.js';
  </script>
</BaseLayout>
