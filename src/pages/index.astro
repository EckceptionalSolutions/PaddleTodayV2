---
import BaseLayout from '../layouts/BaseLayout.astro';
import FeatureIcon from '../components/FeatureIcon.astro';
import { listRivers } from '../lib/rivers';
import indexPageScript from '../scripts/index-page.js?url';

const rivers = listRivers();
const states = [...new Set(rivers.map((river) => river.state))].sort();
const regions = [...new Set(rivers.map((river) => river.region))].sort();
const trackedCount = rivers.length;
---

<BaseLayout
  title="Paddle Today | Can I paddle this river today?"
  description="A live river-conditions MVP that answers whether a river is worth paddling today with a score, confidence, explanation, and key factors."
>
  <section class="decision-hero hero">
    <div class="decision-hero__main">
      <p class="hero__kicker">Paddle Today</p>
      <h1>Where should I paddle today?</h1>
      <p class="hero__lede">
        Start with the best river near you, then compare the strongest backup options for today.
      </p>
      <div class="hero__meta">
        <span class="stat-chip">{trackedCount} routes tracked</span>
        <span class="stat-chip">Direct gauges first</span>
        <span class="stat-chip">Score + confidence + reason</span>
      </div>

      <section class="location-panel" aria-label="Set your location">
        <div class="location-panel__header">
          <div>
            <p class="eyebrow">Your location</p>
            <h2 class="section-title section-title--compact">Find the best rivers near you</h2>
          </div>
          <button class="filter-chip" type="button" data-location-use>
            Use my location
          </button>
        </div>

        <form class="location-panel__form" data-location-form>
          <label class="filter-search location-panel__search">
            <span class="sr-only">Enter a city or ZIP code</span>
            <input
              class="filter-search__input"
              type="search"
              placeholder="Enter a city or ZIP code"
              data-location-input
            />
          </label>
          <button class="filter-chip" type="submit">Set location</button>
          <button class="filter-chip" type="button" data-location-clear hidden>
            Clear
          </button>
        </form>

        <p class="muted location-panel__status" data-location-status>
          Use your location or enter a city or ZIP code to tailor today&apos;s board.
        </p>
      </section>
    </div>

    <aside class="hero-call decision-hero__featured" aria-live="polite">
      <p class="eyebrow" data-best-near-label>Best river right now</p>
      <p class="hero-call__state" data-featured-state>Loading today&apos;s river calls.</p>
      <h2 class="hero-call__title" data-featured-name>Loading best river</h2>
      <p class="hero-call__reach" data-featured-reach>Live river calls are loading.</p>

      <div class="hero-call__scoreline">
        <div class="score-orb score-orb--featured" aria-label="Top river score">
          <span class="score-orb__score" data-field="featured-score">--</span>
          <span class="score-orb__rating" data-field="featured-rating">Loading</span>
        </div>

        <div class="hero-call__meta">
          <span class="pill" data-field="featured-confidence">Confidence loading</span>
          <span class="pill" data-field="featured-distance">Distance loading</span>
        </div>
      </div>

      <p class="hero-call__summary muted" data-field="featured-explanation">
        Pulling the strongest live river call.
      </p>

      <div class="decision-hero__actions">
        <a class="river-link river-link--inline" href="/" data-featured-link>View river</a>
        <a class="river-link river-link--inline river-link--ghost" href="#top-rivers-today">
          See top rivers today
        </a>
      </div>
    </aside>
  </section>

  <section class="decision-section">
    <div class="section-head section-head--stacked">
      <div>
        <p class="eyebrow">Near you</p>
        <h2 class="section-title">Best rivers near you today</h2>
      </div>
      <p class="muted section-head__note" data-nearby-summary>
        Add your location to rank rivers by today&apos;s score and practical driving distance.
      </p>
    </div>
    <div class="river-grid river-grid--decision" data-nearby-grid></div>
    <p class="muted decision-section__empty" data-nearby-empty hidden>
      No rivers match your nearby settings yet.
    </p>
  </section>

  <section class="decision-section" id="top-rivers-today">
    <div class="section-head section-head--stacked">
      <div>
        <p class="eyebrow">Overall</p>
        <h2 class="section-title">Top rivers today</h2>
      </div>
      <p class="muted section-head__note" data-overall-summary>
        The strongest live calls overall, regardless of location.
      </p>
    </div>
    <div class="river-grid river-grid--decision" data-overall-grid></div>
  </section>

  <section class="decision-section decision-section--explore" id="explore">
    <div class="section-head section-head--stacked">
      <div>
        <p class="eyebrow">Explore</p>
        <h2 class="section-title">Browse more rivers</h2>
      </div>
    </div>

    <section class="status-banner status-banner--offline status-banner--hidden" data-board-fetch-banner aria-live="polite">
      <div class="status-banner__eyebrow">Refresh failed</div>
      <div class="status-banner__body">
        <strong data-board-fetch-title>Live river calls could not be refreshed.</strong>
        <p class="muted" data-board-fetch-detail>
          The board may be stale. Retry before you drive.
        </p>
      </div>
    </section>

    <section class="status-banner status-banner--loading" data-board-status-banner aria-live="polite">
      <div class="status-banner__eyebrow">Read quality</div>
      <div class="status-banner__body">
        <strong data-board-banner-title>Checking live reads.</strong>
        <p class="muted" data-board-banner-detail>
          Pulling the latest gauge and weather data.
        </p>
      </div>
    </section>

    <section class="board-filters board-filters--full" aria-label="River board filters">
      <div class="board-filters__meta board-filters__meta--top">
        <p class="muted board-filters__summary" data-filter-summary>
          Loading rivers.
        </p>
        <p class="muted board-filters__summary" data-board-refresh-note>
          Auto-refreshes every 5 minutes.
        </p>
      </div>

      <div class="board-filters__controls">
        <label class="filter-select filter-select--sort">
          <span class="sr-only">Sort the board</span>
          <select class="filter-select__input" data-sort-select>
            <option value="best-now">Best overall</option>
            <option value="near-you">Best near me</option>
            <option value="nearest">Nearest only</option>
            <option value="highest-confidence">Highest confidence</option>
            <option value="lowest-risk">Lowest risk</option>
            <option value="a-z">A-Z</option>
          </select>
        </label>
        <span class="location-indicator" data-location-indicator hidden aria-live="polite">
          <span class="location-indicator__spinner" aria-hidden="true"></span>
          <span data-location-indicator-label>Finding nearest rivers...</span>
        </span>
        <label class="filter-search">
          <span class="sr-only">Search rivers</span>
          <input
            class="filter-search__input"
            type="search"
            placeholder="Search a river or route"
            data-filter-search
          />
        </label>
        <label class="filter-select">
          <span class="sr-only">Filter by state</span>
          <select class="filter-select__input" data-filter-state>
            <option value="">All states</option>
            {states.map((state) => (
              <option value={state}>{state}</option>
            ))}
          </select>
        </label>
        <label class="filter-select">
          <span class="sr-only">Filter by region</span>
          <select class="filter-select__input" data-filter-region>
            <option value="">All regions</option>
            {regions.map((region) => (
              <option value={region}>{region}</option>
            ))}
          </select>
        </label>
        <button class="filter-chip" type="button" data-filter-toggle="paddleable">
          Paddleable only
        </button>
        <button class="filter-chip" type="button" data-filter-toggle="high-confidence">
          High confidence only
        </button>
        <button class="filter-chip" type="button" data-board-refresh>
          Refresh board
        </button>
      </div>
    </section>

    <section class="summary-map-shell" data-summary-map-shell>
      <div class="summary-map-copy">
        <p class="eyebrow section-label">
          <FeatureIcon name="map" size={16} />
          Score map
        </p>
        <h2 class="section-title">River map</h2>
        <p class="muted">
          Each point uses the stored route midpoint. The number is the score. The ring shows confidence.
        </p>

        <div class="summary-map-legend" aria-label="Score map legend">
          <span class="summary-map-legend__item">
            <span class="summary-map-legend__marker summary-map-legend__marker--great">90</span>
            Strong
          </span>
          <span class="summary-map-legend__item">
            <span class="summary-map-legend__marker summary-map-legend__marker--marginal">55</span>
            Borderline
          </span>
          <span class="summary-map-legend__item">
            <span class="score-map-marker score-map-marker--no-go score-map-marker--confidence-low">15</span>
            No-go
          </span>
        </div>
      </div>

      <div class="summary-map-frame">
        <div class="summary-map" data-summary-map aria-label="River score map"></div>
        <p class="summary-map__status muted" data-summary-map-status>
          Loading map.
        </p>
      </div>
    </section>

    <div class="section-head section-head--stacked explore-list-head">
      <div>
        <p class="eyebrow">River list</p>
        <h3 class="section-title">Browse more rivers</h3>
      </div>
    </div>

    <div class="river-grid" aria-label="Explore river calls" data-explore-grid></div>
  </section>

  <template data-river-card-template>
    <article class="river-card river-card--decision">
      <p class="river-card__state" data-field="state"></p>

      <div class="river-card__top">
        <div class="river-card__title-block">
          <h3 class="river-card__title" data-field="name"></h3>
          <p class="river-card__subtitle" data-field="route-label"></p>
        </div>
        <div class="score-orb" aria-label="River score">
          <span class="score-orb__score" data-field="score"></span>
          <span class="score-orb__rating" data-field="rating"></span>
        </div>
      </div>

      <p class="river-card__meta-line" data-field="meta-line"></p>

      <p class="river-card__explanation" data-field="card-summary"></p>
      <p class="river-card__signal-line" data-field="raw-signal"></p>

      <a class="river-link river-link--wide" href="/" data-card-link>View river</a>
    </article>
  </template>

  <script type="module" src={indexPageScript}></script>
</BaseLayout>
