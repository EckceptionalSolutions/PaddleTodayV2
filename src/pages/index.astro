---
import BaseLayout from '../layouts/BaseLayout.astro';
import FeatureIcon from '../components/FeatureIcon.astro';
import { listRivers } from '../lib/rivers';
import indexPageScript from '../scripts/index-page.js?url';

const rivers = listRivers();
const states = [...new Set(rivers.map((river) => river.state))].sort();
const regions = [...new Set(rivers.map((river) => river.region))].sort();
const trackedCount = rivers.length;
const siteUrl = Astro.site?.href ?? 'https://paddletoday.com/';
const homeUrl = new URL('/', siteUrl).href;
const organizationId = new URL('/#organization', siteUrl).href;
const websiteId = new URL('/#website', siteUrl).href;
const homepageStructuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    '@id': websiteId,
    name: 'Paddle Today',
    url: homeUrl,
    publisher: {
      '@id': organizationId,
    },
    inLanguage: 'en-US',
  },
  {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    '@id': `${homeUrl}#collection`,
    name: 'Best Rivers to Paddle Near You Today',
    description:
      'Find the best river to paddle today with live gauge data, weather, score, confidence, and clear launch-day recommendations.',
    url: homeUrl,
    isPartOf: {
      '@id': websiteId,
    },
    about: {
      '@id': organizationId,
    },
  },
];
---

<BaseLayout
  title="Paddle Today | Best Rivers to Paddle Near You Today"
  description="Find the best river to paddle today with live gauge data, weather, score, confidence, and clear launch-day recommendations."
  structuredData={homepageStructuredData}
>
  <section class="decision-hero hero">
    <div class="decision-hero__intro">
      <p class="hero__kicker">Paddle Today</p>
      <h1>Find the best paddle near you today</h1>
      <p class="hero__lede">
        Find the strongest options first, backed by live gauge and weather data.
      </p>
      <p class="hero__snapshot" data-home-snapshot>
        Checking today&apos;s snapshot...
      </p>
      <p class="hero__planning">
        Planning ahead for the weekend?
        <a href="/weekend/" class="hero__planning-link">See our best bets</a>
      </p>
    </div>

    <aside class="hero-call decision-hero__featured" aria-live="polite">
      <p class="eyebrow" data-best-near-label>Today&apos;s clearest call</p>
      <p class="hero-call__state" data-featured-state>Loading stored river snapshot.</p>
      <h2 class="hero-call__title" data-featured-name>Loading best river</h2>
      <p class="hero-call__reach" data-featured-reach>Today&apos;s river scores are loading.</p>
      <p class="hero-call__verdict" data-field="featured-verdict">Loading verdict</p>

      <div class="hero-call__scoreline">
        <div class="score-orb score-orb--featured" aria-label="Top river score">
          <span class="score-orb__score" data-field="featured-score">--</span>
          <span class="score-orb__rating" data-field="featured-rating">Loading</span>
        </div>

        <div class="hero-call__score-meta">
          <div class="hero-call__meta">
          <span class="pill" data-field="featured-confidence">Support loading</span>
          <span class="pill" data-field="featured-distance">Distance loading</span>
          </div>
        </div>
      </div>

      <p class="hero-call__reason" data-field="featured-reason">Loading summary</p>
      <p class="hero-call__signal-line" data-field="featured-signal">Loading live reads</p>
      <ul class="hero-call__reasons" data-featured-reasons></ul>

      <p class="hero-call__summary muted" data-field="featured-explanation">
        Pulling the strongest river for today.
      </p>
      <button class="hero-call__toggle" type="button" data-featured-toggle hidden aria-expanded="false">
        Details
      </button>

      <div class="decision-hero__actions">
        <a class="river-link river-link--inline" href="/" data-featured-link>View river</a>
        <a class="river-link river-link--inline river-link--ghost" href="#explore">
          Browse full board
        </a>
      </div>
    </aside>

    <div class="decision-hero__support">
      <p class="hero__overview-label">Routes overview</p>
      <ul class="hero__call-mix" data-home-call-mix>
        <li class="hero__call-mix-item hero__call-mix-item--good">
          <strong data-home-good-count>--</strong>
          <span>Good</span>
        </li>
        <li class="hero__call-mix-item hero__call-mix-item--mixed">
          <strong data-home-mixed-count>--</strong>
          <span>Mixed</span>
        </li>
        <li class="hero__call-mix-item hero__call-mix-item--no-go">
          <strong data-home-no-go-count>--</strong>
          <span>No-go</span>
        </li>
      </ul>
      <p class="hero__project-label">Project status</p>
      <div class="hero__meta">
        <span class="stat-chip" data-home-tracked-count>{trackedCount} routes tracked</span>
        <span class="stat-chip">Direct gauges first</span>
      </div>
      <p class="hero__note muted">
        Paddle Today is still growing. We&apos;re focusing on the highest-quality Midwest routes first.
        <a href="/request-river/">Request a route</a>
        if there&apos;s one you want to see next.
      </p>
    </div>
  </section>

  <nav class="home-mobile-jump" aria-label="Jump to homepage sections">
    <button class="home-mobile-jump__link" type="button" data-home-jump-target="best-options">
      Best picks
    </button>
    <button class="home-mobile-jump__link" type="button" data-home-jump-target="home-location">
      Nearby
    </button>
    <button class="home-mobile-jump__link" type="button" data-home-jump-target="explore">
      Board
    </button>
    <button class="home-mobile-jump__link" type="button" data-home-jump-target="explore-map">
      Map
    </button>
  </nav>

  <section class="decision-section decision-section--recommended" id="best-options">
    <div class="section-head section-head--stacked">
      <div>
        <p class="eyebrow">Recommended</p>
        <h2 class="section-title" data-recommendation-title>Best paddling options today</h2>
      </div>
      <p class="muted section-head__note" data-recommendation-summary>
        Start here for the fastest answer, then open the full board if you want to compare more rivers.
      </p>
    </div>
    <section class="location-panel" id="home-location" aria-label="Set your location" data-nearby-location-panel hidden>
      <div class="location-panel__header">
        <div>
          <p class="eyebrow">Nearby first</p>
          <h3 class="section-title section-title--compact">Sort by drive time</h3>
        </div>
        <button class="river-link river-link--inline location-panel__cta" type="button" data-location-use>
          Use my location
        </button>
      </div>
      <p class="location-panel__selected" data-location-selected hidden></p>

      <form class="location-panel__form" data-location-form>
        <label class="filter-search location-panel__search">
          <span class="sr-only">Enter a city or ZIP code</span>
          <input
            class="filter-search__input"
            type="search"
            placeholder="Enter a city or ZIP code"
            data-location-input
          />
        </label>
        <div class="location-panel__actions">
          <button class="filter-chip filter-chip--primary" type="submit">Use city</button>
          <button class="filter-chip" type="button" data-location-change hidden>
            Change
          </button>
          <button class="filter-chip" type="button" data-location-clear hidden>
            Clear
          </button>
        </div>
      </form>

    </section>
    <div class="recommendation-grid" data-recommendation-grid></div>
    <p class="muted decision-section__empty" data-recommendation-empty hidden>
      No recommended rivers are available right now.
    </p>
  </section>

  <section class="decision-section decision-section--explore" id="explore">
    <div class="section-head section-head--stacked">
      <div>
        <p class="eyebrow">Explore</p>
        <h2 class="section-title">Full river board</h2>
      </div>
      <p class="muted section-head__note">
        Filters, map, and live reads live here once you want to compare beyond the top recommendations.
      </p>
    </div>

    <div class="decision-section__body" data-explore-content>
      <section class="status-banner status-banner--offline status-banner--hidden" data-board-fetch-banner aria-live="polite">
        <div class="status-banner__eyebrow">Refresh failed</div>
        <div class="status-banner__body">
          <strong data-board-fetch-title>River scores could not be refreshed.</strong>
          <p class="muted" data-board-fetch-detail>
            The board may be stale. Retry before you drive.
          </p>
        </div>
      </section>

      <section class="status-banner status-banner--loading" data-board-status-banner aria-live="polite">
        <div class="status-banner__eyebrow">Read quality</div>
        <div class="status-banner__body">
          <strong data-board-banner-title>Checking live reads.</strong>
          <p class="muted" data-board-banner-detail>
            Pulling the latest gauge and weather data.
          </p>
        </div>
      </section>

      <section class="board-filters board-filters--full" aria-label="River board filters">
        <div class="board-filters__meta board-filters__meta--top">
          <p class="muted board-filters__summary" data-filter-summary>
            Loading rivers.
          </p>
          <p class="muted board-filters__summary" data-board-refresh-note>
            Showing the latest stored board.
          </p>
        </div>

        <div class="board-filters__controls">
          <label class="filter-select filter-select--sort">
            <span class="sr-only">Sort the board</span>
            <select class="filter-select__input" data-sort-select>
              <option value="best-now">Best overall</option>
              <option value="near-you">Best near me</option>
              <option value="nearest">Nearest only</option>
              <option value="highest-confidence">Best supported</option>
              <option value="lowest-risk">Lowest risk</option>
              <option value="a-z">A-Z</option>
            </select>
          </label>
          <span class="location-indicator" data-location-indicator hidden aria-live="polite">
            <span class="location-indicator__spinner" aria-hidden="true"></span>
            <span data-location-indicator-label>Finding nearest rivers...</span>
          </span>
          <label class="filter-search">
            <span class="sr-only">Search rivers</span>
            <input
              class="filter-search__input"
              type="search"
              placeholder="Search a river or route"
              data-filter-search
            />
          </label>
          <label class="filter-select">
            <span class="sr-only">Filter by state</span>
            <select class="filter-select__input" data-filter-state>
              <option value="">All states</option>
              {states.map((state) => (
                <option value={state}>{state}</option>
              ))}
            </select>
          </label>
          <label class="filter-select">
            <span class="sr-only">Filter by region</span>
            <select class="filter-select__input" data-filter-region>
              <option value="">All regions</option>
              {regions.map((region) => (
                <option value={region}>{region}</option>
              ))}
            </select>
          </label>
          <button class="filter-chip" type="button" data-filter-toggle="paddleable">
            Paddleable only
          </button>
          <button class="filter-chip" type="button" data-filter-toggle="high-confidence">
            Best-supported only
          </button>
          <button class="filter-chip" type="button" data-board-refresh>
            Refresh board
          </button>
        </div>
      </section>

      <section class="summary-map-shell" id="explore-map" data-summary-map-shell>
        <div class="summary-map-copy">
          <p class="eyebrow section-label">
            <FeatureIcon name="map" size={16} />
            Score map
          </p>
          <h2 class="section-title">Scan the board on a map</h2>
          <p class="muted">
            Use the filters first, then compare how the current board looks across the region. The number is the score and the ring shows how well-supported the call is.
          </p>
          <button
            class="filter-chip summary-map__toggle"
            type="button"
            data-summary-map-toggle
            hidden
            aria-expanded="true"
          >
            Hide map
          </button>

          <div class="summary-map-legend" aria-label="Score map legend">
            <span class="summary-map-legend__item">
              <span class="summary-map-legend__marker summary-map-legend__marker--great">90</span>
              Strong
            </span>
            <span class="summary-map-legend__item">
              <span class="summary-map-legend__marker summary-map-legend__marker--marginal">55</span>
              Fair
            </span>
            <span class="summary-map-legend__item">
              <span class="score-map-marker score-map-marker--no-go score-map-marker--confidence-low">15</span>
              No-go
            </span>
          </div>
        </div>

        <div class="summary-map-frame">
          <div class="summary-map" data-summary-map aria-label="River score map"></div>
          <p class="summary-map__status muted" data-summary-map-status>
            Loading map.
          </p>
        </div>
      </section>

      <div class="explore-grid-shell" data-explore-shell>
        <div class="river-grid" aria-label="Explore river calls" data-explore-grid></div>
      </div>

      <div class="explore-pagination" data-explore-pagination hidden>
        <p class="muted explore-pagination__summary" data-explore-pagination-summary>
          Showing 1-9 of 9 rivers
        </p>
        <div class="explore-pagination__controls">
          <button class="filter-chip" type="button" data-explore-prev>
            Previous
          </button>
          <span class="explore-pagination__page" data-explore-page>
            Page 1 of 1
          </span>
          <button class="filter-chip" type="button" data-explore-next>
            Next
          </button>
        </div>
      </div>
    </div>

  </section>

  <template data-recommendation-card-template>
    <article class="recommendation-card">
      <div class="recommendation-card__eyebrow-row">
        <p class="recommendation-card__slot" data-field="recommendation-slot"></p>
        <span class="river-card__kind" data-field="recommendation-kind"></span>
      </div>

      <div class="recommendation-card__top">
        <div class="recommendation-card__title-block">
          <p class="recommendation-card__state" data-field="recommendation-state"></p>
          <h3 class="recommendation-card__title" data-field="recommendation-name"></h3>
          <p class="recommendation-card__subtitle" data-field="recommendation-route"></p>
        </div>
      </div>

      <p class="recommendation-card__verdict" data-field="recommendation-verdict"></p>
      <div class="recommendation-card__scoreline">
        <div class="score-orb" aria-label="Recommended river score">
          <span class="score-orb__score" data-field="recommendation-score"></span>
          <span class="score-orb__rating" data-field="recommendation-rating"></span>
        </div>
        <p class="recommendation-card__meta" data-field="recommendation-meta"></p>
      </div>
      <p class="recommendation-card__summary" data-field="recommendation-summary"></p>
      <p class="recommendation-card__signal" data-field="recommendation-signal"></p>
      <ul class="recommendation-card__reasons" data-field="recommendation-reasons"></ul>

      <details class="recommendation-card__details">
        <summary>Details</summary>
        <div class="recommendation-card__details-body">
          <p class="recommendation-card__detail-copy" data-field="recommendation-full"></p>
          <div class="recommendation-card__sources" data-field="recommendation-sources"></div>
        </div>
      </details>

      <a class="river-link river-link--wide" href="/" data-field="recommendation-link">View river</a>
    </article>
  </template>

  <template data-river-card-template>
    <article class="river-card river-card--decision">
      <div class="river-card__eyebrow-row">
        <span class="river-card__kind" data-field="card-kind"></span>
        <p class="river-card__state" data-field="state"></p>
      </div>

      <div class="river-card__top">
        <div class="river-card__title-block">
          <h3 class="river-card__title" data-field="name"></h3>
          <p class="river-card__subtitle" data-field="route-label"></p>
        </div>
      </div>

      <p class="river-card__verdict" data-field="card-verdict"></p>
      <div class="river-card__scoreline">
        <div class="score-orb" aria-label="River score">
          <span class="score-orb__score" data-field="score"></span>
          <span class="score-orb__rating" data-field="rating"></span>
        </div>
        <p class="river-card__meta-line" data-field="meta-line"></p>
      </div>
      <p class="river-card__explanation" data-field="card-summary-main"></p>
      <div class="river-card__signal-line" data-field="raw-signal"></div>

      <a class="river-link river-link--wide" href="/" data-card-link>View river</a>
    </article>
  </template>

  <script type="module" src={indexPageScript}></script>
</BaseLayout>
