---
import BaseLayout from '../layouts/BaseLayout.astro';
import FeatureIcon from '../components/FeatureIcon.astro';
import FavoriteButton from '../components/FavoriteButton.astro';
import { listRivers } from '../lib/rivers';

const rivers = listRivers();
const states = [...new Set(rivers.map((river) => river.state))].sort();
const regions = [...new Set(rivers.map((river) => river.region))].sort();
const trackedCount = rivers.length;
const siteUrl = Astro.site?.href ?? 'https://paddletoday.com/';
const homeUrl = new URL('/', siteUrl).href;
const organizationId = new URL('/#organization', siteUrl).href;
const websiteId = new URL('/#website', siteUrl).href;
const homepageStructuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    '@id': websiteId,
    name: 'Paddle Today',
    url: homeUrl,
    publisher: {
      '@id': organizationId,
    },
    inLanguage: 'en-US',
  },
  {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    '@id': `${homeUrl}#collection`,
    name: 'Best Rivers to Paddle Today',
    description:
      'Find the best river to paddle today with live gauge data, weather, score, confidence, and clear launch-day recommendations.',
    url: homeUrl,
    isPartOf: {
      '@id': websiteId,
    },
    about: {
      '@id': organizationId,
    },
  },
];
---

<BaseLayout
  title="Paddle Today | Best Rivers to Paddle Today"
  description="Find the best river to paddle today with live gauge data, weather, score, confidence, and clear launch-day recommendations."
  structuredData={homepageStructuredData}
>
  <section class="home-hero hero">
    <div class="home-hero__intro">
      <div class="home-hero__copy">
        <p class="hero__kicker">Paddle Today</p>
        <h1 data-home-headline>Find the best paddle near you today</h1>
        <p class="hero__lede">Set a location to rank nearby routes by drive time, river level, and weather.</p>
      </div>

      <div class="home-hero__trust" aria-label="How Paddle Today helps">
        <article class="home-hero__trust-item">
          <span class="home-hero__trust-icon" aria-hidden="true">
            <FeatureIcon name="gauge" size={16} />
          </span>
          <div>
            <p class="home-hero__trust-title">Live river levels</p>
            <p class="home-hero__trust-copy">Gauge and weather checks stay tied to each nearby pick.</p>
          </div>
        </article>
        <article class="home-hero__trust-item">
          <span class="home-hero__trust-icon" aria-hidden="true">
            <FeatureIcon name="car" size={16} />
          </span>
          <div>
            <p class="home-hero__trust-title">Drive-aware picks</p>
            <p class="home-hero__trust-copy">Routes rank by score, distance, and how far you actually have to drive.</p>
          </div>
        </article>
        <article class="home-hero__trust-item">
          <span class="home-hero__trust-icon" aria-hidden="true">
            <FeatureIcon name="clock" size={16} />
          </span>
          <div>
            <p class="home-hero__trust-title">Fits your day</p>
            <p class="home-hero__trust-copy">Refine by difficulty and paddle time without leaving the homepage.</p>
          </div>
        </article>
      </div>

      <section class="home-location-bar home-hero__location" id="home-location" aria-label="Set your location" data-nearby-location-panel>
        <button
          class="home-location-bar__current"
          type="button"
          data-location-edit-trigger
        >
          <span class="home-location-bar__icon" aria-hidden="true">&#x1F4CD;</span>
          <div class="home-location-bar__text">
            <p class="home-location-bar__value" data-home-location-summary>Set your location to see drive times</p>
            <p class="home-location-bar__helper" data-home-location-sort-summary>
              Use GPS or enter a city to personalize nearby routes.
            </p>
          </div>
        </button>

        <form class="location-panel__form home-location-bar__form" data-location-form>
          <label class="filter-search location-panel__search home-location-bar__search">
            <span class="sr-only">Enter a city or ZIP code</span>
            <input
              class="filter-search__input home-location-bar__search-input"
              type="search"
              placeholder="City or ZIP code"
              data-location-input
            />
          </label>
          <div class="location-panel__actions home-location-bar__actions">
            <button class="river-link river-link--inline home-location-bar__use" type="button" data-location-use>
              <FeatureIcon name="crosshair" size={17} />
              Use my location
            </button>
            <button class="filter-chip home-location-bar__clear" type="button" data-location-clear hidden>Clear</button>
          </div>
        </form>

        <div class="home-location-bar__refine" data-home-refine-row hidden>
          <div class="home-location-bar__refine-copy">
            <p class="home-location-bar__refine-radius" data-home-radius-summary>Showing routes within 100 miles</p>
            <p class="home-location-bar__refine-summary muted" data-home-refine-summary>Any difficulty • Any paddle time</p>
          </div>
          <div class="home-location-bar__refine-actions">
            <span class="home-location-bar__refine-count" data-home-match-count>Showing 0 routes</span>
            <button
              class="filter-chip filter-chip--subtle home-location-bar__filters-toggle"
              type="button"
              data-home-filter-toggle
              hidden
              aria-expanded="false"
            >
              <FeatureIcon name="sliders" size={16} />
              <span data-home-filter-toggle-label>Refine preferences</span>
              <span class="home-location-bar__filters-toggle-count" data-home-filter-toggle-count>0 routes</span>
            </button>
          </div>
        </div>

        <div class="home-filter-sheet-backdrop" data-home-filter-backdrop hidden></div>

        <div class="home-radius-panel" data-home-radius-panel hidden>
          <div class="home-radius-panel__mobile-head">
            <div>
              <p class="home-radius-panel__eyebrow">Nearby filters</p>
              <p class="home-radius-panel__mobile-copy">Tune the nearby route list without leaving the homepage.</p>
            </div>
            <button class="filter-chip filter-chip--quiet home-radius-panel__close" type="button" data-home-filter-close>
              Close
            </button>
          </div>

          <div class="home-radius-panel__presets" aria-label="Filter presets">
            <button class="filter-chip filter-chip--subtle home-radius-panel__preset" type="button" data-home-preset="quick-float">
              Quick Float
            </button>
            <button class="filter-chip filter-chip--subtle home-radius-panel__preset" type="button" data-home-preset="full-day">
              Full Day
            </button>
            <button class="filter-chip filter-chip--quiet home-radius-panel__preset" type="button" data-home-reset-filters>
              Reset all filters
            </button>
          </div>

          <div class="home-radius-panel__filters" aria-label="Nearby route preferences">
            <section class="home-filter-group home-filter-group--distance" aria-labelledby="home-filter-distance">
              <div class="home-filter-group__head">
                <span class="home-filter-group__icon" aria-hidden="true">
                  <FeatureIcon name="car" size={16} />
                </span>
                <div>
                  <p class="home-radius-panel__field-label" id="home-filter-distance">Drive Distance</p>
                </div>
              </div>

              <label class="home-radius-panel__slider-wrap">
                <span class="sr-only">Recommendation radius in miles</span>
                <input
                  class="home-radius-panel__slider"
                  type="range"
                  min="0"
                  max="5"
                  step="1"
                  value="3"
                  data-home-radius-slider
                />
              </label>

              <div class="home-radius-panel__scale" aria-hidden="true">
                <span>25 mi</span>
                <span>50 mi</span>
                <span>75 mi</span>
                <span>100 mi</span>
                <span>150 mi</span>
                <span>200 mi</span>
              </div>
            </section>

            <section class="home-filter-group" aria-labelledby="home-filter-difficulty">
              <div class="home-filter-group__head">
                <span class="home-filter-group__icon" aria-hidden="true">
                  <FeatureIcon name="mountain" size={16} />
                </span>
                <div>
                  <p class="home-radius-panel__field-label" id="home-filter-difficulty">Difficulty</p>
                </div>
              </div>
              <div class="home-radius-panel__choices" role="group" aria-label="Difficulty">
                <button class="filter-chip filter-chip--subtle home-radius-panel__choice" type="button" data-home-difficulty-button data-value="any">
                  Any
                </button>
                <button class="filter-chip filter-chip--subtle home-radius-panel__choice" type="button" data-home-difficulty-button data-value="easy">
                  Easy
                </button>
                <button class="filter-chip filter-chip--subtle home-radius-panel__choice" type="button" data-home-difficulty-button data-value="moderate">
                  Moderate
                </button>
                <button class="filter-chip filter-chip--subtle home-radius-panel__choice" type="button" data-home-difficulty-button data-value="hard">
                  Hard
                </button>
              </div>
            </section>

            <section class="home-filter-group" aria-labelledby="home-filter-paddle-time">
              <div class="home-filter-group__head">
                <span class="home-filter-group__icon" aria-hidden="true">
                  <FeatureIcon name="clock" size={16} />
                </span>
                <div>
                  <p class="home-radius-panel__field-label" id="home-filter-paddle-time">Paddle Time</p>
                </div>
              </div>
              <div class="home-radius-panel__choices" role="group" aria-label="Paddle time">
                <button class="filter-chip filter-chip--subtle home-radius-panel__choice" type="button" data-home-paddle-time-button data-value="any">
                  Any
                </button>
                <button class="filter-chip filter-chip--subtle home-radius-panel__choice" type="button" data-home-paddle-time-button data-value="up-to-3">
                  Under 3 hr
                </button>
                <button class="filter-chip filter-chip--subtle home-radius-panel__choice" type="button" data-home-paddle-time-button data-value="3-to-5">
                  3-5 hr
                </button>
                <button class="filter-chip filter-chip--subtle home-radius-panel__choice" type="button" data-home-paddle-time-button data-value="5-to-7">
                  5-7 hr
                </button>
                <button class="filter-chip filter-chip--subtle home-radius-panel__choice" type="button" data-home-paddle-time-button data-value="7-plus">
                  7+ hr
                </button>
              </div>
            </section>
          </div>

          <div class="home-radius-panel__footer">
            <p class="home-radius-panel__footer-copy muted" data-home-live-count>
              0 routes match your filters
            </p>
            <button class="filter-chip filter-chip--quiet home-radius-panel__footer-reset" type="button" data-home-reset-filters>
              Reset filters
            </button>
          </div>
        </div>
      </section>

    </div>

    <aside class="home-hero__rail" aria-label="Today&apos;s best">
      <section class="hero-call home-featured home-featured--locked" data-home-featured>
        <div class="home-featured__lock">
          <p class="home-featured__lock-label">Today&apos;s best</p>
          <p class="home-featured__lock-copy">Set your location to reveal the strongest paddle near you.</p>
        </div>

        <div class="home-featured__body">
          <div class="home-featured__header">
            <p class="eyebrow" data-best-near-label>Today&apos;s best</p>
            <p class="hero-call__state" data-featured-state>Set your location to reveal the strongest paddle near you.</p>
            <h2 class="hero-call__title">
              <a class="title-link title-link--hero" href="#best-options" data-field="featured-title-link">Today&apos;s best</a>
            </h2>
            <p class="hero-call__reach" data-featured-reach>We&apos;ll show the strongest nearby route once drive times are active.</p>
          </div>

          <div class="hero-call__scoreline">
            <div class="score-orb score-orb--featured" aria-label="Today&apos;s best score">
              <span class="score-orb__score" data-field="featured-score">--</span>
              <span class="score-orb__rating" data-field="featured-rating">Locked</span>
            </div>

            <div class="hero-call__score-meta">
              <p class="hero-call__verdict" data-field="featured-verdict">Set your location</p>
              <p class="hero-call__reason" data-field="featured-reason">Drive times and route ranking appear after you choose a location.</p>
              <div class="hero-call__meta">
                <span class="pill" data-field="featured-confidence">Support pending</span>
                <span class="pill" data-field="featured-distance">Add location for drive time</span>
              </div>
            </div>
          </div>

          <details class="river-score-tooltip home-score-breakdown hero-call__score-breakdown" data-score-breakdown hidden>
            <summary class="river-score-tooltip__summary">
              <span>Why this score</span>
            </summary>
            <div class="river-score-tooltip__panel">
              <p class="muted river-score-tooltip__intro" data-score-breakdown-summary>
                Checking how today&apos;s score comes together.
              </p>
              <div class="river-score-tooltip__rows" data-score-breakdown-rows></div>
              <div class="river-score-tooltip__caps" data-score-breakdown-caps-wrap hidden>
                <p class="river-score-tooltip__caps-label">What limited today&apos;s score</p>
                <ul class="compact-list river-score-tooltip__caps-list" data-score-breakdown-caps></ul>
              </div>
            </div>
          </details>

          <div class="home-featured__map-shell" data-featured-map-shell hidden>
            <div class="summary-map home-featured__map" data-featured-map aria-label="Map showing the featured route location"></div>
            <p class="home-featured__map-status" data-featured-map-status>Route location</p>
          </div>

          <p class="hero-call__signal-line" data-field="featured-signal">Gauge, weather, and support details will appear here.</p>
          <p class="hero-call__summary muted" data-field="featured-explanation">Location unlocks the full summary and drive-time-aware recommendation.</p>
          <button class="hero-call__toggle" type="button" data-featured-toggle hidden>Details</button>
          <ul class="hero-call__reasons" data-featured-reasons hidden></ul>
          <div class="home-featured__actions">
            <a class="river-link river-link--inline river-link--wide river-link--primary home-featured__link" href="#best-options" data-featured-link>Set location first</a>
            <a class="river-link river-link--inline river-link--wide home-featured__link home-featured__link--secondary" href="#best-options">
              See other top picks
            </a>
          </div>
        </div>
      </section>
    </aside>
  </section>

  <section class="decision-section decision-section--recommended home-recommendations" id="best-options">
    <div class="section-head section-head--stacked">
      <div>
        <p class="eyebrow">Recommended</p>
        <h2 class="section-title" data-recommendation-title>Best routes near you</h2>
      </div>
      <div class="section-head__actions home-recommendations__actions">
        <p class="muted section-head__note home-recommendations__intro-note" data-recommendation-summary>
          Set your location to see personalized best routes near you.
        </p>
        <div class="section-head__controls home-recommendations__controls">
          <span class="home-recommendations__count" data-recommendation-count>Showing 0 routes</span>
          <label class="filter-select filter-select--sort home-recommendations__sort">
            <span class="sr-only">Sort nearby route results</span>
            <select class="filter-select__input" data-nearby-sort-select>
              <option value="best-score">Best score</option>
              <option value="closest">Closest</option>
              <option value="shortest-paddle">Shortest paddle</option>
              <option value="easiest">Easiest</option>
            </select>
          </label>
          <button class="filter-chip filter-chip--quiet home-recommendations__reset" type="button" data-home-reset-filters>
            Reset filters
          </button>
        </div>
        <div class="home-radius-pills home-recommendations__mix" aria-label="Route mix within selected radius" data-home-route-mix hidden>
          <span class="home-radius-pill home-radius-pill--strong">
            <strong data-home-strong-count>0</strong>
            <span>Strong</span>
          </span>
          <span class="home-radius-pill home-radius-pill--good">
            <strong data-home-good-count>0</strong>
            <span>Good</span>
          </span>
          <span class="home-radius-pill home-radius-pill--fair">
            <strong data-home-mixed-count>0</strong>
            <span>Fair</span>
          </span>
          <span class="home-radius-pill home-radius-pill--no-go">
            <strong data-home-no-go-count>0</strong>
            <span>No-go</span>
          </span>
        </div>
      </div>
    </div>

    <div class="home-recommendations__shell">
      <div class="home-location-empty" data-home-location-empty>
        <p class="home-location-empty__headline">Set your location to reveal the strongest paddle near you.</p>
      </div>

      <div class="recommendation-grid recommendation-grid--home" data-recommendation-grid></div>
    </div>

    <p class="muted decision-section__empty" data-recommendation-empty hidden>
      No recommended rivers are available right now.
    </p>
  </section>

  <section class="home-overview" aria-label="Board overview">
    <section class="home-board-inline" aria-label="Route requests">
      <p class="home-board-inline__copy">Don&apos;t see your favorite river?</p>
      <a class="river-link river-link--inline river-link--ghost" href="/request-river/">Request a route</a>
    </section>
  </section>

  <section class="decision-section home-nearby-map" id="explore-map" data-home-nearby-map-section hidden>
    <div class="section-head section-head--stacked">
      <div>
        <p class="eyebrow">Nearby map</p>
        <h2 class="section-title">See your matching routes on the map</h2>
      </div>
      <div class="section-head__actions home-nearby-map__actions">
        <p class="muted section-head__note">
          Every route here matches your current location, radius, difficulty, and paddle-time preferences.
        </p>
        <a class="river-link river-link--inline river-link--ghost" href="/explore/">Browse all routes</a>
      </div>
    </div>

    <section class="summary-map-shell summary-map-shell--nearby" data-summary-map-shell data-summary-map-mode="nearby">
      <div class="summary-map-copy">
        <p class="eyebrow section-label">
          <FeatureIcon name="map" size={16} />
          Nearby route map
        </p>
        <h2 class="section-title">Compare the routes that fit your setup</h2>
        <p class="muted summary-map-copy__lede">
          Use the map to scan every nearby match, then open the full browse page when you want deeper filters.
        </p>
        <div class="summary-map-results-head">
          <p class="summary-map-results__title">Matching routes</p>
          <p class="muted summary-map-results__note" data-summary-map-results-note>Loading routes.</p>
        </div>
        <div class="summary-map-results" data-summary-map-results aria-live="polite"></div>
        <button class="filter-chip summary-map__toggle" type="button" data-summary-map-toggle hidden aria-expanded="true">Hide map</button>
      </div>

      <div class="summary-map-frame">
        <div class="summary-map" data-summary-map aria-label="Map showing nearby matching routes"></div>
        <div class="summary-map-footer">
          <p class="summary-map__status muted" data-summary-map-status>Loading nearby routes.</p>
          <div class="summary-map-legend" aria-label="Score map legend">
            <span class="summary-map-legend__item">
              <span class="summary-map-legend__marker summary-map-legend__marker--great">90</span>
              Strong
            </span>
            <span class="summary-map-legend__item">
              <span class="summary-map-legend__marker summary-map-legend__marker--marginal">55</span>
              Fair
            </span>
            <span class="summary-map-legend__item">
              <span class="score-map-marker score-map-marker--no-go score-map-marker--confidence-low">15</span>
              No-go
            </span>
          </div>
        </div>
      </div>
    </section>
  </section>

  <!-- Template hydrated by index-page.js for the three best-route cards. -->
  <template data-recommendation-card-template>
    <article class="recommendation-card">
      <div class="recommendation-card__eyebrow-row">
        <div class="recommendation-card__eyebrow-meta">
          <p class="recommendation-card__slot" data-field="recommendation-slot"></p>
          <span class="river-card__kind" data-field="recommendation-kind"></span>
        </div>
        <FavoriteButton className="favorite-toggle favorite-toggle--card" hidden />
      </div>

      <div class="recommendation-card__top">
        <div class="recommendation-card__title-block">
          <p class="recommendation-card__state" data-field="recommendation-state"></p>
          <h3 class="recommendation-card__title">
            <a class="title-link" href="/" data-field="recommendation-title-link"></a>
          </h3>
          <p class="recommendation-card__subtitle" data-field="recommendation-route"></p>
        </div>
      </div>

      <div class="recommendation-card__scoreline">
        <div class="score-orb" aria-label="Recommended river score">
          <span class="score-orb__score" data-field="recommendation-score"></span>
          <span class="score-orb__rating" data-field="recommendation-rating"></span>
        </div>
        <div class="recommendation-card__score-copy">
          <p class="recommendation-card__verdict" data-field="recommendation-verdict"></p>
          <p class="recommendation-card__meta" data-field="recommendation-meta"></p>
        </div>
      </div>
      <details class="river-score-tooltip home-score-breakdown recommendation-card__score-breakdown" data-score-breakdown hidden>
        <summary class="river-score-tooltip__summary">
          <span>Why this score</span>
        </summary>
        <div class="river-score-tooltip__panel">
          <p class="muted river-score-tooltip__intro" data-score-breakdown-summary>
            Checking how this score comes together.
          </p>
          <div class="river-score-tooltip__rows" data-score-breakdown-rows></div>
          <div class="river-score-tooltip__caps" data-score-breakdown-caps-wrap hidden>
            <p class="river-score-tooltip__caps-label">What limited today&apos;s score</p>
            <ul class="compact-list river-score-tooltip__caps-list" data-score-breakdown-caps></ul>
          </div>
        </div>
      </details>
      <p class="recommendation-card__summary" data-field="recommendation-summary"></p>
      <div class="recommendation-card__tags" data-field="recommendation-tags" hidden></div>
      <p class="recommendation-card__live-label" data-field="recommendation-live-label" hidden>Live conditions</p>
      <p class="recommendation-card__signal" data-field="recommendation-signal"></p>
      <ul class="recommendation-card__reasons" data-field="recommendation-reasons"></ul>

      <details class="recommendation-card__details">
        <summary>Details</summary>
        <div class="recommendation-card__details-body">
          <p class="recommendation-card__detail-copy" data-field="recommendation-full"></p>
          <div class="recommendation-card__sources" data-field="recommendation-sources"></div>
        </div>
      </details>

      <a class="river-link river-link--wide" href="/" data-field="recommendation-link">View river</a>
    </article>
  </template>

  <!-- Template hydrated by index-page.js for the full board cards. -->
  <template data-river-card-template>
    <article class="river-card river-card--decision">
      <div class="river-card__eyebrow-row">
        <div class="river-card__eyebrow-meta">
          <span class="river-card__kind" data-field="card-kind"></span>
          <p class="river-card__state" data-field="state"></p>
        </div>
        <FavoriteButton className="favorite-toggle favorite-toggle--card" hidden />
      </div>

      <div class="river-card__top">
        <div class="river-card__title-block">
          <h3 class="river-card__title">
            <a class="title-link" href="/" data-field="card-title-link"></a>
          </h3>
          <p class="river-card__subtitle" data-field="route-label"></p>
        </div>
        <span class="river-card__warning" data-field="card-warning" hidden></span>
      </div>

      <p class="river-card__verdict" data-field="card-verdict"></p>
      <div class="river-card__scoreline">
        <div class="score-orb" aria-label="River score">
          <span class="score-orb__score" data-field="score"></span>
          <span class="score-orb__rating" data-field="rating"></span>
        </div>
        <p class="river-card__meta-line" data-field="meta-line"></p>
      </div>
      <p class="river-card__explanation" data-field="card-summary-main"></p>
      <div class="river-card__signal-line" data-field="raw-signal"></div>

      <a class="river-link river-link--wide" href="/" data-card-link>View river</a>
    </article>
  </template>

