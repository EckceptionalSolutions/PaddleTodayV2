---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { listRiverStateGroups } from '../../lib/rivers';

const siteUrl = Astro.site?.href ?? 'https://paddletoday.com/';
const guidesUrl = new URL('/guides/', siteUrl).href;
const organizationId = new URL('/#organization', siteUrl).href;
const websiteId = new URL('/#website', siteUrl).href;
const stateGroups = listRiverStateGroups();
const guideLinks = [
  {
    href: '/guides/best-minnesota-paddle-trips/',
    title: 'Best Minnesota Paddle Trips',
    description: 'Weekend routes, long day trips, canoe-camping ideas, and beginner-friendly paddles with live scores where available.',
    label: 'Minnesota guide',
  },
  {
    href: '/guides/best-weekend-paddle-trips-minnesota/',
    title: 'Best Weekend Paddle Trips in Minnesota',
    description: 'A live shortlist of Minnesota routes that look promising for the weekend and also have decent current scores.',
    label: 'Weekend guide',
  },
];
const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  '@id': `${guidesUrl}#collection`,
  name: 'Paddle Today Guides',
  description: 'Paddle Today guides for planning Midwest paddle trips with route links, live water-level context, weather, and source-backed route notes.',
  url: guidesUrl,
  isPartOf: {
    '@id': websiteId,
  },
  about: {
    '@id': organizationId,
  },
};
---

<BaseLayout
  title="Paddling Guides | Paddle Today"
  description="Browse Paddle Today guides for Midwest paddle trips, weekend route ideas, state route coverage, live water-level context, and source-backed planning notes."
  structuredData={structuredData}
>
  <section class="guide-hero guide-hero--flagship">
    <div class="guide-hero__copy">
      <p class="hero__kicker">Guides</p>
      <h1>Paddling Guides</h1>
      <p class="guide-hero__lede">
        Plan route ideas first, then open the route pages for current water levels, weather, scores, access notes, and source confidence.
      </p>
    </div>
    <aside class="guide-hero__note">
      <p class="eyebrow">Coverage note</p>
      <p>Guides link back to tracked routes where Paddle Today has enough source support for live scoring.</p>
    </aside>
  </section>

  <section class="guide-section" aria-labelledby="featured-guides-title">
    <div class="section-head section-head--stacked">
      <div>
        <p class="eyebrow">Featured</p>
        <h2 class="section-title" id="featured-guides-title">Current trip guides</h2>
      </div>
    </div>
    <div class="guide-explainer__grid">
      {guideLinks.map((guide) => (
        <article class="guide-explainer__item">
          <p class="eyebrow">{guide.label}</p>
          <h3>{guide.title}</h3>
          <p>{guide.description}</p>
          <p>
            <a class="river-link river-link--inline" href={guide.href}>
              Open guide
            </a>
          </p>
        </article>
      ))}
    </div>
  </section>

  <section class="guide-section" aria-labelledby="state-guides-title">
    <div class="section-head section-head--stacked">
      <div>
        <p class="eyebrow">State coverage</p>
        <h2 class="section-title" id="state-guides-title">Tracked routes by state</h2>
      </div>
      <p class="muted section-head__note">
        State pages are crawlable route indexes and good starting points for future state-specific guides.
      </p>
    </div>
    <div class="state-link-grid state-link-grid--compact">
      {stateGroups.map((state) => (
        <article class="state-link-card">
          <h3>{state.name}</h3>
          <p class="muted">
            {state.routeCount} {state.routeCount === 1 ? 'route' : 'routes'} across {state.riverCount} {state.riverCount === 1 ? 'river' : 'rivers'}
          </p>
          <a class="river-link river-link--inline river-link--ghost" href={`/states/${state.slug}/`}>
            Browse {state.name}
          </a>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
