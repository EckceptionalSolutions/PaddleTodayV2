---
import BaseLayout from '../layouts/BaseLayout.astro';

const siteUrl = Astro.site?.href ?? 'https://paddletoday.com/';
const websiteId = new URL('/#website', siteUrl).href;
const organizationId = new URL('/#organization', siteUrl).href;
const aboutUrl = new URL('/about/', siteUrl).href;
const aboutStructuredData = {
  '@context': 'https://schema.org',
  '@type': 'AboutPage',
  '@id': `${aboutUrl}#about-page`,
  name: 'About Paddle Today',
  description:
    'Learn how Paddle Today scores rivers, explains confidence, and chooses which rivers are reliable enough to track live.',
  url: aboutUrl,
  isPartOf: {
    '@id': websiteId,
  },
  about: {
    '@id': organizationId,
  },
};
---

<BaseLayout
  title="About Paddle Today | How River Scores Work"
  description="Learn how Paddle Today scores rivers, explains confidence, and chooses which rivers are reliable enough to track live."
  structuredData={aboutStructuredData}
>
  <section class="info-hero">
    <p class="eyebrow">About Paddle Today</p>
    <h1>Helping more people feel confident about paddling.</h1>
    <p class="muted">
      Paddle Today started from a simple idea: figuring out where to paddle should feel easier, clearer, and less intimidating. The goal is to help more people get on the water with a straightforward read before they pack the car.
    </p>
    <div class="info-hero__actions">
      <a class="river-link river-link--inline" href="/request-river/">Request a river</a>
      <a class="river-link river-link--inline river-link--ghost" href="/contact/">Contact us</a>
    </div>
    <p class="muted">
      If you have questions, want a river added, or have an idea that would make the site more useful, <a href="/contact/">get in touch</a>.
    </p>
  </section>

  <section class="info-grid" aria-label="How Paddle Today works">
    <article class="info-card">
      <p class="eyebrow">Method</p>
      <h2>How the call is made</h2>
      <p class="muted">
        Each river combines current gauge value, recent trend, weather risk, seasonality, and route notes. The result is a score, a confidence level, and a short plain-language summary.
      </p>
    </article>

    <article class="info-card">
      <p class="eyebrow">Confidence</p>
      <h2>Why some rivers score better than others</h2>
      <p class="muted">
        Confidence depends on the freshness and quality of the inputs. Direct gauges, stronger published ranges, and current weather reads lead to stronger scores. Stale or thin evidence lowers confidence.
      </p>
    </article>

    <article class="info-card">
      <p class="eyebrow">Coverage</p>
      <h2>Why coverage starts small</h2>
      <p class="muted">
        This is a new project, so we are starting with the highest-quality sources first. Right now the focus is the Midwest, especially Minnesota, Wisconsin, and Iowa, where we can match good gauge coverage with usable route guidance. Coverage will expand from there as the source quality holds up.
      </p>
    </article>
  </section>

  <section class="info-panel">
    <p class="eyebrow">Ground rules</p>
    <h2>Always verify before you launch.</h2>
    <p class="muted">
      River levels, weather, access, and hazards can change quickly. Paddle Today is a planning tool, not a substitute for local judgment, source verification, or on-the-ground scouting.
    </p>
    <ul class="compact-list">
      <li>Check the original gauge and source links on the river page.</li>
      <li>Recheck weather, wind, and storms before you drive.</li>
      <li>Confirm put-in, take-out, parking, and land-access rules locally.</li>
    </ul>
  </section>
</BaseLayout>
