    <section class="river-detail__chapter-head river-detail__chapter-head--understand" aria-label="Understand chapter">
      <p class="eyebrow section-label">Understand</p>
      <h2 class="river-detail__chapter-title">See what is driving today&apos;s call.</h2>
      <p class="muted river-detail__chapter-copy">
        The deeper evidence, support level, outlook, and source links live here when you want to verify the recommendation.
      </p>
    </section>

    <section class="river-detail__panel river-accordion-group" id="why-this-call" data-detail-section="why-this-call" data-detail-nav-group="understand">
        <details class="river-accordion" data-confidence-explainer>
          <summary class="river-accordion__summary">
            <span>
              <span class="eyebrow section-label">Why this score</span>
              <strong>Today&apos;s support level is {` `}<span data-field="confidence-detail-label">checking</span></strong>
            </span>
          </summary>
          <div class="river-accordion__body">
            <p class="muted confidence-detail__intro">
              This trust read comes from three things: how direct the gauge is, how clear the range is, and how fresh the live reads are.
            </p>

          <div class="confidence-detail__groups">
            <section class="confidence-detail__group">
              <span class="eyebrow section-label">Why</span>
              <ul class="confidence-rationale" data-confidence-reasons>
                <li>Checking support reasons.</li>
              </ul>
            </section>

            <section class="confidence-detail__group" data-confidence-warnings-group hidden>
              <span class="eyebrow section-label">Watch for</span>
              <ul class="confidence-rationale confidence-rationale--warnings" data-confidence-warnings>
                <li>Checking support warnings.</li>
              </ul>
            </section>
          </div>
        </div>
      </details>

      <details class="river-accordion">
        <summary class="river-accordion__summary">
          <span>
            <span class="eyebrow section-label">Outlook</span>
            <strong>Tomorrow and weekend</strong>
          </span>
        </summary>
        <div class="river-accordion__body">
          <p class="muted">
            Conservative directional reads only. Withheld when support is too weak.
          </p>
          <div class="outlook-grid" data-outlooks>
            <article class="outlook-card">
              <span class="outlook-card__label">Tomorrow</span>
              <strong>Checking</strong>
              <p class="muted">Waiting on forecast.</p>
            </article>
            <article class="outlook-card">
              <span class="outlook-card__label">Weekend</span>
              <strong>Checking</strong>
              <p class="muted">Waiting on forecast.</p>
            </article>
          </div>
        </div>
      </details>

        <details class="river-accordion">
          <summary class="river-accordion__summary">
            <span>
              <span class="eyebrow section-label">Data behind the score</span>
              <strong>Gauge, thresholds, and timing</strong>
            </span>
          </summary>
          <div class="river-accordion__body">
            <p class="muted confidence-detail__intro">
              These are the live inputs and threshold notes behind today&apos;s score.
            </p>
          <table class="detail-table">
            <tbody>
              <tr>
                <td>Gauge site</td>
                <td>{river.gaugeSource.siteName}</td>
              </tr>
              <tr>
                <td>Current gauge</td>
                <td data-field="gauge-now">Checking</td>
              </tr>
              <tr>
                <td>Current discharge</td>
                <td data-field="discharge-now">Checking</td>
              </tr>
              <tr>
                <td>24h trend</td>
                <td data-field="trend">Checking</td>
              </tr>
              <tr>
                <td>24h change</td>
                <td data-field="flow-change-24h">Checking</td>
              </tr>
              <tr>
                <td>Current band</td>
                <td data-field="flow-band">Checking</td>
              </tr>
              <tr>
                <td>Rain last 24h</td>
                <td data-field="recent-rain-24h">Checking</td>
              </tr>
              <tr>
                <td>Rain last 72h</td>
                <td data-field="recent-rain-72h">Checking</td>
              </tr>
              <tr>
                <td>Air temp</td>
                <td data-field="weather-air-temp">Checking</td>
              </tr>
              <tr>
                <td>Water temp</td>
                <td data-field="weather-water-temp">Checking</td>
              </tr>
              <tr>
                <td>Wind</td>
                <td data-field="weather-wind">Checking</td>
              </tr>
              <tr>
                <td>Gusts</td>
                <td data-field="weather-gusts">Checking</td>
              </tr>
              <tr>
                <td>Rain timing</td>
                <td data-field="weather-rain-risk">Checking</td>
              </tr>
              <tr>
                <td>{targetBandLabel}</td>
                <td>{targetBandValue}</td>
              </tr>
              <tr>
                <td>Low threshold</td>
                <td>{lowThresholdValue}</td>
              </tr>
              <tr>
                <td>High threshold</td>
                <td>{highThresholdValue}</td>
              </tr>
              <tr>
                <td>Support behind the range</td>
                <td>{thresholdSupportLabel}</td>
              </tr>
              <tr>
                <td>Gauge observed</td>
                <td data-field="observed-at">Checking</td>
              </tr>
                <tr>
                  <td>Paddle Today updated</td>
                  <td data-field="generated-at">Checking</td>
                </tr>
              <tr>
                <td>Main source behind this score</td>
                <td>{river.profile.thresholdSource.label}</td>
              </tr>
              <tr>
                <td>Gauge source</td>
                <td data-field="gauge-source">Checking</td>
              </tr>
              <tr>
                <td>Weather source</td>
                <td data-field="weather-source">Checking</td>
              </tr>
              <tr>
                <td>Rainfall source</td>
                <td data-field="rainfall-source">Checking</td>
              </tr>
            </tbody>
          </table>
        </div>
      </details>

      <details class="river-accordion">
        <summary class="river-accordion__summary">
          <span>
            <span class="eyebrow section-label">Notes</span>
            <strong>What to know before you go</strong>
          </span>
        </summary>
        <div class="river-accordion__body">
          <p class="muted confidence-detail__intro">
            These notes call out the access details, route quirks, and source caveats most likely to matter on the ground.
          </p>
          <ul class="factor-list">
            {river.evidenceNotes.map((note) => (
              <li class="factor-item impact-neutral">
                <div class="factor-item__head">
                  <span class="factor-item__label">{note.label}</span>
                  <span class="factor-item__value">{note.value}</span>
                </div>
                {note.note ? <p class="muted" style="margin: 0.55rem 0 0;">{note.note}</p> : null}
                {note.sourceUrl ? (
                  <p style="margin: 0.55rem 0 0;">
                    <a href={note.sourceUrl} target="_blank" rel="noreferrer">
                      Source
                    </a>
                  </p>
                ) : null}
              </li>
            ))}
          </ul>
        </div>
      </details>

        <details class="river-accordion">
          <summary class="river-accordion__summary">
            <span>
              <span class="eyebrow section-label">Verify it yourself</span>
              <strong>Check the original sources</strong>
            </span>
          </summary>
        <div class="river-accordion__body">
          <p class="muted confidence-detail__intro">
            Use these links to verify the gauge, route details, and access notes before you drive.
          </p>
          <ul class="source-list">
            {river.sourceLinks.map((source) => (
              <li>
                <a href={source.url} target="_blank" rel="noreferrer">{source.label}</a>
              </li>
            ))}
          </ul>
        </div>
      </details>
    </section>

    <section class="river-detail__chapter-head river-detail__chapter-head--contribute" aria-label="Contribute chapter">
      <p class="eyebrow section-label">Contribute</p>
      <h2 class="river-detail__chapter-title">Add route knowledge for the next paddler.</h2>
      <p class="muted river-detail__chapter-copy">
        Share trip reports, upload photos, or flag anything on the page that needs to be corrected.
      </p>
    </section>

    <section class="river-detail__panel river-report-panel" data-detail-section="share-trip" data-detail-nav-group="contribute">
      <p class="eyebrow section-label">
        <FeatureIcon name="camera" size={16} />
        Share your trip
      </p>
      <div class="river-report-panel__content route-contribute" id="share-trip">
        <div class="route-contribute__intro">
          <h2 class="river-subtitle river-subtitle--compact">Send a trip report or route photos</h2>
          <p class="muted">
            Share what this route looked like, how it paddled, and anything useful the next paddler should know.
          </p>
          <ul class="compact-list route-gallery__tips">
            <li>Photos should show access, on-water character, hazards, or what the route actually looked like.</li>
            <li>Trip reports are most useful when they mention level, pace, strainers, obstructions, or access changes.</li>
            <li>Contributors should only upload photos they took or have permission to share.</li>
          </ul>
        </div>

        <div class="route-contribute__form-shell">
          <section class="route-gallery__pending" data-route-gallery-pending hidden>
            <div class="route-gallery__pending-head">
              <div>
                <p class="route-gallery__pending-kicker">Pending upload</p>
                <h3 class="route-gallery__pending-title" data-route-gallery-pending-title>Selected for upload</h3>
              </div>
              <p class="muted route-gallery__pending-note" data-route-gallery-pending-note>
                These previews are only visible in this browser.
              </p>
            </div>
            <div class="route-gallery__pending-grid" data-route-gallery-pending-grid></div>
          </section>

          <form class="request-form route-photo-form" data-route-photo-form novalidate>
            <div class="route-photo-form__grid">
              <label>
                Your name *
                <input name="contributorName" maxlength="120" autocomplete="name" placeholder="Full name or paddling handle" data-route-photo-name />
              </label>

              <label>
                Your email *
                <input
                  name="contributorEmail"
                  type="email"
                  maxlength="160"
                  autocomplete="email"
                  placeholder="you@example.com"
                  data-route-photo-email
                />
              </label>
            </div>

            <div class="route-photo-form__grid route-photo-form__grid--meta">
              <label>
                Trip date
                <input name="tripDate" type="date" data-route-trip-date />
              </label>

              <label>
                How did it feel?
                <select name="tripSentiment" data-route-trip-sentiment>
                  <option value="">Select one</option>
                  <option value="great">Great day</option>
                  <option value="good">Good but watchable</option>
                  <option value="mixed">Mixed</option>
                  <option value="rough">Rough / sketchy</option>
                </select>
              </label>
            </div>

            <label>
              Trip review
              <span class="request-form__hint">Share how it paddled, what the access looked like, and anything others should know.</span>
              <textarea
                name="tripReport"
                rows="5"
                maxlength="1800"
                placeholder="Example: Water was moving well, put-in parking was easy, one new strainer on river right about halfway down, and the take-out stairs were slick."
                data-route-trip-report
              ></textarea>
            </label>

            <label>
              Photos
              <span class="request-form__hint">Optional. Up to 4 JPG, PNG, or WebP images. Maximum 4 MB each.</span>
              <input
                type="file"
                name="photos"
                accept="image/jpeg,image/png,image/webp"
                multiple
                data-route-photo-files
              />
            </label>

            <p class="muted route-photo-form__selection" data-route-photo-selection>
              No files selected yet.
            </p>

            <label>
              Photo or trip notes
              <span class="request-form__hint">Optional extra context for the upload or review.</span>
              <textarea
                name="notes"
                rows="4"
                maxlength="1200"
                placeholder="Example: These photos are from the put-in and the bridge bend. Medium spring flow, taken April 12."
                data-route-photo-notes
              ></textarea>
            </label>

            <label class="route-photo-form__checkbox">
              <input type="checkbox" name="rightsConfirmed" data-route-photo-rights />
              <span>I took these photos or have clear permission to share them.</span>
            </label>

            <label class="route-photo-form__checkbox">
              <input type="checkbox" name="reviewConsent" data-route-photo-consent />
              <span>Paddle Today can review this submission and contact me if more context is needed before publishing.</span>
            </label>

            <label class="request-form__hp" aria-hidden="true">
              Leave this blank
              <input name="company" tabindex="-1" autocomplete="off" data-route-photo-company />
            </label>

            <div class="request-form__actions">
              <button class="filter-chip" type="submit" data-route-photo-submit>Send for review</button>
            </div>

            <p class="muted request-form__status route-photo-form__status" data-route-photo-status aria-live="polite"></p>
          </form>
        </div>
      </div>
    </section>

    <section class="river-detail__panel river-report-panel" data-detail-section="flag-change" data-detail-nav-group="contribute">
      <p class="eyebrow section-label">
        <FeatureIcon name="compass" size={16} />
        Flag a change
      </p>
      <div class="river-report-panel__content">
        <div>
          <h2 class="river-subtitle river-subtitle--compact">Spotted something outdated?</h2>
          <p class="muted">
            Access rules, hazards, wood, shuttle details, and threshold notes change. Send a quick correction if something on this page looks off.
          </p>
        </div>
        <div class="detail-map__links">
          <a class="river-link river-link--inline" href={reportChangeHref}>
            Report a change
          </a>
          <a class="river-link river-link--inline" href={reportChangeEmail}>
            Email update
          </a>
        </div>
      </div>
    </section>
      </div>
    </div>
    <script>
      import '../../scripts/river-detail-page.js';
    </script>
  </article>
</BaseLayout>
