      data-detail-nav-group="reports"
      data-route-gallery
      data-approved-photos={approvedRoutePhotosJson}
    >
      <div class="route-gallery__intro">
        <div class="route-gallery__intro-copy">
          <p class="eyebrow section-label">
            <FeatureIcon name="camera" size={16} />
            Route gallery
          </p>
          <h2 class="section-title">See this route on the water</h2>
          <p class="muted route-gallery__lede">
          Photos help show what the access looks like and what the route actually feels like on the water.
          </p>
        </div>
      </div>

      <div class="route-gallery__layout">
        <div class="route-gallery__viewer" data-route-gallery-viewer>
          {approvedRoutePhotos.length > 0 ? (
            <>
              <figure class="route-gallery__figure" data-route-gallery-figure>
                <img
                  class="route-gallery__image"
                  src={approvedRoutePhotos[0].src}
                  alt={approvedRoutePhotos[0].alt}
                  loading="eager"
                  data-route-gallery-image
                />
                <figcaption class="route-gallery__caption">
                  <div class="route-gallery__caption-copy">
                    <strong data-route-gallery-caption>{approvedRoutePhotos[0].caption}</strong>
                    <span class="muted" data-route-gallery-credit>
                      {approvedRoutePhotos[0].credit ? `Photo by ${approvedRoutePhotos[0].credit}` : 'Approved community photo'}
                    </span>
                  </div>
                  <span class="route-gallery__caption-tag" data-route-gallery-taken hidden={!approvedRoutePhotos[0].takenLabel}>
                    {approvedRoutePhotos[0].takenLabel ?? ''}
                  </span>
                </figcaption>
              </figure>

              {approvedRoutePhotos.length > 1 ? (
                <div class="route-gallery__thumbs" data-route-gallery-thumbs aria-label="Approved route photos">
                  {approvedRoutePhotos.map((photo, index) => (
                    <button
                      class:list={['route-gallery__thumb', index === 0 && 'route-gallery__thumb--active']}
                      type="button"
                      data-route-gallery-thumb
                      data-route-gallery-index={index}
                      aria-pressed={index === 0 ? 'true' : 'false'}
                    >
                      <img src={photo.src} alt="" loading="lazy" />
                      <span>{photo.caption}</span>
                    </button>
                  ))}
                </div>
              ) : null}
            </>
          ) : (
            <div class="route-gallery__empty" data-route-gallery-empty>
              <div class="route-gallery__empty-art" aria-hidden="true">
                <img src="/gallery/fallbacks/river-fallback-wide.jpg" alt="" loading="lazy" />
                <img src="/gallery/fallbacks/river-fallback-stream.jpg" alt="" loading="lazy" />
                <img src="/gallery/fallbacks/river-fallback-marsh.jpg" alt="" loading="lazy" />
              </div>
              <div class="route-gallery__empty-copy">
                <h3 class="route-gallery__empty-title">No approved route photos yet</h3>
                <p class="muted">
                  Start the gallery with shots of the access, river character, or any detail that helps paddlers know what this run actually looks like.
                </p>
                <div class="route-gallery__cta-row">
                  <a
                    class="river-link river-link--inline"
                    href="#share-trip"
                    data-analytics-event="Open route report"
                  >
                    Share photos or a trip report
                  </a>
                </div>
              </div>
            </div>
          )}
        </div>
      </div>
    </section>

    <section class="river-detail__chapter-head river-detail__chapter-head--understand" aria-label="Sources chapter">
      <p class="eyebrow section-label">Sources</p>
      <h2 class="river-detail__chapter-title">Check the data behind today&apos;s call.</h2>
      <p class="muted river-detail__chapter-copy">
        Use this section when the page shows stale data, limited confidence, or a call you want to verify before driving.
      </p>
    </section>

    <section class="status-banner status-banner--loading" data-detail-status-banner aria-live="polite">
      <div class="status-banner__eyebrow">Read quality</div>
      <div class="status-banner__body">
        <strong data-detail-banner-title>Checking live inputs.</strong>
        <p class="muted" data-detail-banner-detail>
          Pulling the latest gauge and weather. Usually under 10 seconds.
        </p>
      </div>
      <div class="status-banner__grid" data-detail-reliability-grid>
        <article class="status-banner__item">
          <span class="status-banner__label">Gauge input</span>
          <strong data-field="reliability-gauge-title">Checking</strong>
          <p class="muted" data-field="reliability-gauge-detail">
            Waiting on the gauge read.
          </p>
        </article>
        <article class="status-banner__item">
          <span class="status-banner__label">Weather input</span>
          <strong data-field="reliability-weather-title">Checking</strong>
          <p class="muted" data-field="reliability-weather-detail">
            Waiting on weather.
          </p>
        </article>
        <article class="status-banner__item">
          <span class="status-banner__label">Next step</span>
          <strong data-field="reliability-action-title">Checking</strong>
          <p class="muted" data-field="reliability-action-detail">
            Waiting on enough data to give the next step.
          </p>
        </article>
      </div>
    </section>

    <section class="river-detail__panel river-accordion-group" id="why-this-call" data-detail-section="why-this-call" data-detail-nav-group="sources">
        <details class="river-accordion" data-confidence-explainer>
          <summary class="river-accordion__summary">
            <span>
              <span class="eyebrow section-label">Why this score</span>
              <strong>Today&apos;s data confidence is {` `}<span data-field="confidence-detail-label">checking</span></strong>
            </span>
          </summary>
          <div class="river-accordion__body">
            <p class="muted confidence-detail__intro">
          Data confidence mostly comes down to three things: how direct the gauge is, how clear the range is, and how fresh the data is.
            </p>

          <div class="confidence-detail__groups">
            <section class="confidence-detail__group">
              <span class="eyebrow section-label">Why</span>
              <ul class="confidence-rationale" data-confidence-reasons>
              <li>Checking data confidence notes.</li>
              </ul>
            </section>

            <section class="confidence-detail__group" data-confidence-warnings-group hidden>
              <span class="eyebrow section-label">Watch for</span>
              <ul class="confidence-rationale confidence-rationale--warnings" data-confidence-warnings>
              <li>Checking data confidence cautions.</li>
              </ul>
            </section>
          </div>
        </div>
      </details>

      <details class="river-accordion">
        <summary class="river-accordion__summary">
          <span>
            <span class="eyebrow section-label">Outlook</span>
            <strong>Tomorrow and weekend</strong>
          </span>
        </summary>
        <div class="river-accordion__body">
          <p class="muted">
          This is a cautious early look. If the data is too thin, we leave it out.
          </p>
          <div class="outlook-grid" data-outlooks>
            <article class="outlook-card">
              <span class="outlook-card__label">Tomorrow</span>
              <strong>Checking</strong>
              <p class="muted">Waiting on forecast.</p>
            </article>
            <article class="outlook-card">
              <span class="outlook-card__label">Weekend</span>
              <strong>Checking</strong>
              <p class="muted">Waiting on forecast.</p>
            </article>
          </div>
        </div>
      </details>

        <details class="river-accordion">
          <summary class="river-accordion__summary">
            <span>
              <span class="eyebrow section-label">Data behind the score</span>
              <strong>Gauge, thresholds, and timing</strong>
            </span>
          </summary>
          <div class="river-accordion__body">
            <p class="muted confidence-detail__intro">
        These are the live readings and threshold notes behind today's score.
            </p>
          <table class="detail-table">
            <tbody>
              <tr>
                <td>Gauge site</td>
                <td>{river.gaugeSource.siteName}</td>
              </tr>
              <tr>
                <td data-field="primary-gauge-label">Current gauge</td>
                <td data-field="gauge-now">Checking</td>
              </tr>
              <tr>
                <td data-field="secondary-gauge-label">Current discharge</td>
                <td data-field="discharge-now">Checking</td>
              </tr>
              <tr>
                <td>24h trend</td>
                <td data-field="trend">Checking</td>
              </tr>
              <tr>
                <td>24h change</td>
                <td data-field="flow-change-24h">Checking</td>
              </tr>
              <tr>
                <td>Current band</td>
                <td data-field="flow-band">Checking</td>
              </tr>
              <tr>
                <td>Rain last 24h</td>
                <td data-field="recent-rain-24h">Checking</td>
              </tr>
              <tr>
                <td>Rain last 72h</td>
                <td data-field="recent-rain-72h">Checking</td>
              </tr>
              <tr>
                <td>Air temp</td>
                <td data-field="weather-air-temp">Checking</td>
              </tr>
              <tr>
                <td>Water temp</td>
                <td data-field="weather-water-temp">Checking</td>
              </tr>
              <tr>
                <td>Wind</td>
                <td data-field="weather-wind">Checking</td>
              </tr>
              <tr>
                <td>Gusts</td>
                <td data-field="weather-gusts">Checking</td>
              </tr>
              <tr>
                <td>Rain timing</td>
                <td data-field="weather-rain-risk">Checking</td>
              </tr>
              <tr>
                <td>{targetBandLabel}</td>
                <td>{targetBandValue}</td>
              </tr>
              <tr>
                <td>{isMinimumOnlyRoute ? 'Known low-water floor' : 'Low threshold'}</td>
                <td>{lowThresholdValue}</td>
              </tr>
              <tr>
                <td>High threshold</td>
                <td>{highThresholdValue}</td>
              </tr>
              <tr>
                <td>Data confidence behind the range</td>
                <td>{thresholdConfidenceLabel}</td>
              </tr>
              <tr>
                <td>Gauge observed</td>
                <td data-field="observed-at">Checking</td>
              </tr>
                <tr>
                  <td>Paddle Today updated</td>
                  <td data-field="generated-at">Checking</td>
                </tr>
              <tr>
                <td>Main source behind this score</td>
                <td>{river.profile.thresholdSource.label}</td>
              </tr>
              <tr>
                <td>Gauge source</td>
                <td data-field="gauge-source">Checking</td>
              </tr>
              <tr>
                <td>Weather source</td>
                <td data-field="weather-source">Checking</td>
              </tr>
              <tr>
                <td>Rainfall source</td>
                <td data-field="rainfall-source">Checking</td>
              </tr>
            </tbody>
          </table>
        </div>
      </details>

      <details class="river-accordion">
        <summary class="river-accordion__summary">
          <span>
            <span class="eyebrow section-label">Notes</span>
            <strong>What to know before you go</strong>
          </span>
        </summary>
        <div class="river-accordion__body">
          <p class="muted confidence-detail__intro">
        These notes cover the access details, route quirks, and source caveats most likely to matter once you get there.
          </p>
          <ul class="factor-list">
            {river.evidenceNotes.map((note) => (
              <li class="factor-item impact-neutral">
                <div class="factor-item__head">
                  <span class="factor-item__label">{note.label}</span>
                  <span class="factor-item__value">{note.value}</span>
                </div>
                {note.note ? <p class="muted" style="margin: 0.55rem 0 0;">{note.note}</p> : null}
                {note.sourceUrl ? (
                  <p style="margin: 0.55rem 0 0;">
                    <a href={note.sourceUrl} target="_blank" rel="noreferrer">
                      Source
                    </a>
                  </p>
                ) : null}
              </li>
            ))}
          </ul>
        </div>
      </details>

        <details class="river-accordion">
          <summary class="river-accordion__summary">
            <span>
              <span class="eyebrow section-label">Verify it yourself</span>
          <strong>Check the source links</strong>
            </span>
          </summary>
        <div class="river-accordion__body">
          <p class="muted confidence-detail__intro">
        Use these links to double-check the gauge, route details, and access notes before you head out.
          </p>
          <ul class="source-list">
            {river.sourceLinks.map((source) => (
              <li>
                <a href={source.url} target="_blank" rel="noreferrer">{source.label}</a>
              </li>
            ))}
          </ul>
        </div>
      </details>
    </section>

    <section
      class="river-detail__panel route-community"
      data-route-community
      data-detail-section="community-reports"
      data-detail-nav-group="reports"
      hidden
    >
      <div class="route-gallery__intro">
        <div class="route-gallery__intro-copy">
          <p class="eyebrow section-label">
            <FeatureIcon name="compass" size={16} />
            Route reports
          </p>
          <h2 class="section-title">Recent notes from paddlers</h2>
          <p class="muted route-gallery__lede">
            A few quick notes from people who were on this route recently.
          </p>
        </div>
        <div class="route-gallery__stats route-community__stats" data-route-community-stats hidden>
          <span class="pill" data-route-community-count></span>
          <span class="pill" data-route-community-freshness></span>
        </div>
      </div>
      <div class="route-community__list" data-route-community-list></div>
      <div class="route-gallery__cta-row route-community__cta-row">
        <a
          class="river-link river-link--inline"
          href="#share-trip"
          data-route-report-cta
          data-analytics-event="Open route report"
        >
          Send a route report
        </a>
      </div>
    </section>

    <section class="river-detail__chapter-head river-detail__chapter-head--contribute" aria-label="Reports chapter">
      <p class="eyebrow section-label">Reports</p>
      <h2 class="river-detail__chapter-title">Photos, paddler notes, and updates.</h2>
      <p class="muted river-detail__chapter-copy">
        See what others have shared, then add a trip report, upload photos, or flag anything that needs fixing.
      </p>
    </section>

    <section class="river-detail__panel river-report-panel" data-detail-section="share-trip" data-detail-nav-group="reports">
      <p class="eyebrow section-label">
        <FeatureIcon name="camera" size={16} />
        Share your trip
      </p>
      <div class="river-report-panel__content route-contribute" id="share-trip">
        <div class="route-contribute__intro">
          <h2 class="river-subtitle river-subtitle--compact">Help build the route page</h2>
          <p class="muted">Add photos or send a quick route report.</p>
        </div>

        <div class="route-contribute__tabs" role="tablist" aria-label="Contribution options">
          <button
            class="route-contribute__tab route-contribute__tab--active"
            type="button"
            role="tab"
            aria-selected="true"
            aria-controls="share-photos-panel"
            id="share-photos-tab"
            data-route-contribute-tab="photo"
          >
            Upload photos
          </button>
          <button
            class="route-contribute__tab"
            type="button"
            role="tab"
            aria-selected="false"
            aria-controls="share-report-panel"
          id="share-report-tab"
          data-route-contribute-tab="report"
        >
            Send report
          </button>
        </div>

        <div class="route-contribute__form-shell">
          <section
            class="route-contribute__panel route-contribute__panel--photo"
            role="tabpanel"
            id="share-photos-panel"
            aria-labelledby="share-photos-tab"
            data-route-contribute-panel="photo"
          >
            <div class="route-contribute__panel-head">
              <p class="route-contribute__panel-kicker">Photos</p>
              <h3>Upload route photos</h3>
              <p class="muted">Add access, hazard, or on-water photos.</p>
            </div>

            <section class="route-gallery__pending" data-route-gallery-pending hidden>
              <div class="route-gallery__pending-head">
                <div>
                  <p class="route-gallery__pending-kicker">Pending upload</p>
                  <h3 class="route-gallery__pending-title" data-route-gallery-pending-title>Selected for upload</h3>
                </div>
                <p class="muted route-gallery__pending-note" data-route-gallery-pending-note>
                  These previews are only visible in this browser.
                </p>
              </div>
              <div class="route-gallery__pending-grid" data-route-gallery-pending-grid></div>
            </section>

            <form
              class="request-form route-photo-form"
              data-route-photo-form
              data-analytics-event="Submit route photos"
              novalidate
            >
              <div class="route-photo-form__grid">
                <label>
                  Your name *
                  <input name="contributorName" maxlength="120" autocomplete="name" placeholder="Full name or paddling handle" data-route-photo-name />
                </label>

                <label>
                  Your email *
                  <input
                    name="contributorEmail"
                    type="email"
                    maxlength="160"
                    autocomplete="email"
                    placeholder="you@example.com"
                    data-route-photo-email
                  />
                </label>
              </div>

              <div class="route-photo-form__grid route-photo-form__grid--meta">
                <label>
                  Trip date
                  <input name="tripDate" type="date" data-route-trip-date />
                </label>

                <label>
                  Photos
                  <span class="request-form__hint">Up to 4 images, 4 MB max each.</span>
                  <input
                    type="file"
                    name="photos"
                    accept="image/jpeg,image/png,image/webp"
                    multiple
                    data-route-photo-files
                  />
                </label>
              </div>

              <p class="muted route-photo-form__selection" data-route-photo-selection>
                No files selected yet.
              </p>

              <label>
                Photo notes
                <span class="request-form__hint">Optional. Add a little context.</span>
                <textarea
                  name="notes"
                  rows="4"
                  maxlength="1200"
                  placeholder="Example: Put-in at medium spring flow. Last photo shows the bridge bend halfway through."
                  data-route-photo-notes
                ></textarea>
              </label>

              <label class="route-photo-form__checkbox">
                <input type="checkbox" name="rightsConfirmed" data-route-photo-rights />
                <span>I took these photos or have clear permission to share them.</span>
              </label>

              <label class="route-photo-form__checkbox">
                <input type="checkbox" name="reviewConsent" data-route-photo-consent />
                <span>It's okay to contact me if you need more detail before publishing.</span>
              </label>

              <label class="request-form__hp" aria-hidden="true">
                Leave this blank
                <input name="company" tabindex="-1" autocomplete="off" data-route-photo-company />
              </label>

              <div class="request-form__actions">
                <button class="filter-chip" type="submit" data-route-photo-submit>Upload photos</button>
              </div>

              <p class="muted request-form__status route-photo-form__status" data-route-photo-status aria-live="polite"></p>
            </form>
          </section>

          <section
            class="route-contribute__panel route-contribute__panel--report"
            role="tabpanel"
            id="share-report-panel"
            aria-labelledby="share-report-tab"
            data-route-contribute-panel="report"
            hidden
          >
            <div class="route-contribute__panel-head">
              <p class="route-contribute__panel-kicker">Route report</p>
              <h3>Send a route report</h3>
              <p class="muted">A few honest notes about level, pace, wood, or access changes go a long way.</p>
            </div>

            <form
              class="request-form route-photo-form"
              data-route-report-form
              data-analytics-event="Submit route report"
              novalidate
            >
              <div class="route-photo-form__grid">
                <label>
                  Your name *
                  <input name="contributorName" maxlength="120" autocomplete="name" placeholder="Full name or paddling handle" data-route-report-name />
                </label>

                <label>
                  Your email *
                  <input
                    name="contributorEmail"
                    type="email"
                    maxlength="160"
                    autocomplete="email"
                    placeholder="you@example.com"
                    data-route-report-email
                  />
                </label>
              </div>

              <div class="route-photo-form__grid route-photo-form__grid--meta">
                <label>
                  Trip date
                  <input name="tripDate" type="date" data-route-report-date />
                </label>

                <label>
                  How did it feel?
                  <select name="tripSentiment" data-route-report-sentiment>
                    <option value="">Select one</option>
                    <option value="great">Great day</option>
                    <option value="good">Good but watchable</option>
                    <option value="mixed">Mixed</option>
                    <option value="rough">Rough / sketchy</option>
                  </select>
                </label>
              </div>

              <label>
                Route report
                <span class="request-form__hint">Share how it paddled and what others should know.</span>
                <textarea
                  name="tripReport"
                  rows="5"
                  maxlength="1800"
                  placeholder="Example: Water was moving well, put-in parking was easy, one new strainer on river right about halfway down, and the take-out stairs were slick."
                  data-route-report-text
                ></textarea>
              </label>

              <label>
                Extra notes
                <span class="request-form__hint">Optional extra context.</span>
                <textarea
                  name="notes"
                  rows="4"
                  maxlength="1200"
                  placeholder="Example: We paddled it in just under three hours and the wood was easy to spot."
                  data-route-report-notes
                ></textarea>
              </label>

              <label>
                Photos
                <span class="request-form__hint">Optional. Add up to 4 images.</span>
                <input
                  type="file"
                  name="photos"
                  accept="image/jpeg,image/png,image/webp"
                  multiple
                  data-route-report-files
                />
              </label>

              <p class="muted route-photo-form__selection" data-route-report-selection>
                No files selected.
              </p>

              <label class="route-photo-form__checkbox">
                <input type="checkbox" name="rightsConfirmed" data-route-report-rights />
                <span>If you add photos, I took them or have clear permission to share them.</span>
              </label>

              <label class="route-photo-form__checkbox">
                <input type="checkbox" name="reviewConsent" data-route-report-consent />
                <span>It's okay to contact me if you need more detail before publishing.</span>
              </label>

              <label class="request-form__hp" aria-hidden="true">
                Leave this blank
                <input name="company" tabindex="-1" autocomplete="off" data-route-report-company />
              </label>

              <div class="request-form__actions">
                <button class="filter-chip" type="submit" data-route-report-submit>Send route report</button>
              </div>

              <p class="muted request-form__status route-photo-form__status" data-route-report-status aria-live="polite"></p>
            </form>
          </section>
        </div>
      </div>
    </section>

    <section class="river-detail__panel river-report-panel" data-detail-section="flag-change" data-detail-nav-group="reports">
      <p class="eyebrow section-label">
        <FeatureIcon name="compass" size={16} />
        Flag a change
      </p>
      <div class="river-report-panel__content">
        <div>
          <h2 class="river-subtitle river-subtitle--compact">See something outdated?</h2>
          <p class="muted">
            Access, hazards, wood, and shuttle details change. Send a quick correction if something looks off.
          </p>
        </div>
        <div class="detail-map__links">
          <a
            class="river-link river-link--inline"
            href={reportChangeHref}
            data-analytics-event="Open route update"
          >
            Report a change
          </a>
          <a
            class="river-link river-link--inline"
            href={reportChangeEmail}
            data-analytics-event="Open route update email"
          >
            Email update
          </a>
        </div>
      </div>
    </section>
      </div>
    </div>
    <script>
      import '../../scripts/river-detail-page.js';
    </script>
  </article>
</BaseLayout>
