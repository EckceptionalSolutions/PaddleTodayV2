---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FeatureIcon from '../../components/FeatureIcon.astro';
import { getApprovedRoutePhotos } from '../../data/route-gallery';
import { FAVORITE_STAR_PATH } from '../../lib/favorites-icon.js';
import { listRivers } from '../../lib/rivers';

export function getStaticPaths() {
  return listRivers().map((river) => ({
    params: { slug: river.slug },
    props: { river },
  }));
}

const { river } = Astro.props;
const thresholdSupportLabel =
  river.profile.thresholdSourceStrength === 'official'
    ? 'Backed by official guidance'
    : river.profile.thresholdSourceStrength === 'mixed'
      ? 'Backed by official and local guidance'
      : river.profile.thresholdSourceStrength === 'community'
        ? 'Based on local route guidance'
        : 'Built from Paddle Today calibration';
const formatThresholdValue = (value: number | undefined) => {
  if (typeof value !== 'number') {
    return 'Not calibrated yet';
  }

  if (river.gaugeSource.unit === 'cfs') {
    return `${Math.round(value).toLocaleString('en-US')} ${river.gaugeSource.unit}`;
  }

  return `${value.toFixed(2).replace(/\\.00$/, '')} ${river.gaugeSource.unit}`;
};
const targetBandLabel = river.profile.thresholdModel === 'minimum-only' ? 'Working range' : 'Target band';
const targetBandValue =
  river.profile.thresholdModel === 'two-sided' &&
  typeof river.profile.idealMin === 'number' &&
  typeof river.profile.idealMax === 'number'
    ? `${formatThresholdValue(river.profile.idealMin)} to ${formatThresholdValue(river.profile.idealMax)}`
    : 'Not calibrated yet';
const lowThresholdValue = formatThresholdValue(river.profile.tooLow);
const highThresholdValue = formatThresholdValue(river.profile.tooHigh);
const putIn = river.putIn;
const takeOut = river.takeOut;
const logistics = river.logistics;
const putInMapsUrl =
  typeof putIn?.latitude === 'number' && typeof putIn?.longitude === 'number'
    ? `https://www.google.com/maps?q=${putIn.latitude},${putIn.longitude}`
    : undefined;
const takeOutMapsUrl =
  typeof takeOut?.latitude === 'number' && typeof takeOut?.longitude === 'number'
    ? `https://www.google.com/maps?q=${takeOut.latitude},${takeOut.longitude}`
    : undefined;
const directionsGoogleUrl =
  typeof putIn?.latitude === 'number' &&
  typeof putIn?.longitude === 'number' &&
  typeof takeOut?.latitude === 'number' &&
  typeof takeOut?.longitude === 'number'
    ? `https://www.google.com/maps/dir/?api=1&origin=${encodeURIComponent(`${putIn.latitude},${putIn.longitude}`)}&destination=${encodeURIComponent(`${takeOut.latitude},${takeOut.longitude}`)}`
    : undefined;
const directionsAppleUrl =
  typeof putIn?.latitude === 'number' &&
  typeof putIn?.longitude === 'number' &&
  typeof takeOut?.latitude === 'number' &&
  typeof takeOut?.longitude === 'number'
    ? `https://maps.apple.com/?saddr=${encodeURIComponent(`${putIn.latitude},${putIn.longitude}`)}&daddr=${encodeURIComponent(`${takeOut.latitude},${takeOut.longitude}`)}&dirflg=d`
    : undefined;
const openStreetMapUrl = `https://www.openstreetmap.org/?mlat=${river.latitude}&mlon=${river.longitude}#map=11/${river.latitude}/${river.longitude}`;
const shuttleHeadline = logistics?.shuttle.toLowerCase().includes('bike') ? 'Car or bike' : 'Car shuttle';
const permitsHeadline =
  logistics?.permits.startsWith('No') || logistics?.permits.startsWith('N/A')
    ? 'None noted'
    : 'Check posted rules';
const campingHeadline =
  logistics?.camping.startsWith('No') ||
  logistics?.camping.startsWith('N/A') ||
  logistics?.camping.toLowerCase().includes('day trip')
    ? 'Day trip'
    : 'Options nearby';
const seasonMonthLabels = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
const seasonMonths = river.profile.seasonMonths ?? [];
const firstSeasonMonth = seasonMonths.length > 0 ? seasonMonthLabels[seasonMonths[0] - 1] : null;
const lastSeasonMonth = seasonMonths.length > 0 ? seasonMonthLabels[seasonMonths[seasonMonths.length - 1] - 1] : null;
const seasonHeadline =
  firstSeasonMonth && lastSeasonMonth
    ? firstSeasonMonth === lastSeasonMonth
      ? firstSeasonMonth
      : `${firstSeasonMonth}-${lastSeasonMonth}`
    : 'Check seasonal notes';
const primaryAccessCaveat = logistics?.accessCaveats?.[0] ?? 'Check parking, launch, and access rules on the ground.';
const secondaryAccessCaveat = logistics?.accessCaveats?.[1] ?? primaryAccessCaveat;
const reportChangeHref =
  `/request-river/?mode=update&routeName=${encodeURIComponent(`${river.name} - ${river.reach}`)}&state=${encodeURIComponent(river.state)}` +
  `${putIn?.name ? `&putIn=${encodeURIComponent(putIn.name)}` : ''}` +
  `${takeOut?.name ? `&takeOut=${encodeURIComponent(takeOut.name)}` : ''}` +
  `${river.profile.thresholdSource.url ? `&sources=${encodeURIComponent(river.profile.thresholdSource.url)}` : ''}` +
  `&notes=${encodeURIComponent(
    `River: ${river.name} - ${river.reach}\n\nI noticed this might need an update:\n- \n\nWhat changed or looked wrong:\n- \n`
  )}`;
const reportChangeEmail = `mailto:routes@paddletoday.com?subject=${encodeURIComponent(`River update: ${river.name} (${river.state})`)}&body=${encodeURIComponent(
  `River: ${river.name} - ${river.reach}\nState: ${river.state}\nPut-in: ${putIn?.name ?? 'N/A'}\nTake-out: ${takeOut?.name ?? 'N/A'}\n\nWhat might need an update:\n- \n`
)}`;
const hasAccessPlanner = (river.accessPoints?.length ?? 0) > 2;
const accessPlannerPointsJson = JSON.stringify(river.accessPoints ?? []);
const siblingRoutes = listRivers()
  .filter((candidate) => candidate.riverId === river.riverId && candidate.slug !== river.slug)
  .sort((left, right) => left.reach.localeCompare(right.reach));
const riverHubHref = siblingRoutes.length > 0 ? `/rivers/by-river/${river.riverId}/` : null;
const siteUrl = Astro.site?.href ?? 'https://paddletoday.com/';
const homeUrl = new URL('/', siteUrl).href;
const routeUrl = new URL(`/rivers/${river.slug}/`, siteUrl).href;
const riverHubUrl = riverHubHref ? new URL(riverHubHref, siteUrl).href : null;
const routeShareTitle = `${river.name}: ${river.reach} | Paddle Today`;
const routeShareDescription = `Check ${river.name} for ${river.reach}. Live gauge, weather, support level, access details, and today's paddle score before you drive.`;
const routeShareText = `Check today's paddle score for ${river.name} - ${river.reach} on Paddle Today. Live gauge, weather, support level, and access details.`;
const approvedRoutePhotos = getApprovedRoutePhotos(river.slug);
const approvedRoutePhotosJson = JSON.stringify(approvedRoutePhotos);
const breadcrumbItems = [
  {
    '@type': 'ListItem',
    position: 1,
    name: 'Home',
    item: homeUrl,
  },
  ...(riverHubUrl
    ? [
        {
          '@type': 'ListItem',
          position: 2,
          name: river.name,
          item: riverHubUrl,
        },
        {
          '@type': 'ListItem',
          position: 3,
          name: `${river.name}: ${river.reach}`,
          item: routeUrl,
        },
      ]
    : [
        {
          '@type': 'ListItem',
          position: 2,
          name: `${river.name}: ${river.reach}`,
          item: routeUrl,
        },
      ]),
];
const routeStructuredData = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  '@id': `${routeUrl}#breadcrumbs`,
  itemListElement: breadcrumbItems,
};
---

<BaseLayout
  title={`${river.name} Today | ${river.reach} | Paddle Today`}
  description={`Check ${river.name} today for ${river.reach}. See live gauge data, weather, score, support level, and a clear paddling recommendation before you drive.`}
  socialTitle={routeShareTitle}
  socialDescription={routeShareDescription}
  socialImage="/brand/paddle-today-share-card-1200x630.png"
  socialImageAlt="Paddle Today route share preview"
  socialImageWidth={1200}
  socialImageHeight={630}
  ogType="article"
  twitterCard="summary_large_image"
>
  <script type="application/ld+json" set:html={JSON.stringify(routeStructuredData)}></script>
  <article
    class="river-detail"
    data-river-detail
    data-river-slug={river.slug}
    data-river-id={river.riverId}
    data-river-name={river.name}
    data-river-reach={river.reach}
    data-river-state={river.state}
    data-river-region={river.region}
    data-put-in-name={putIn?.name}
    data-put-in-latitude={putIn?.latitude}
    data-put-in-longitude={putIn?.longitude}
    data-take-out-name={takeOut?.name}
    data-take-out-latitude={takeOut?.latitude}
    data-take-out-longitude={takeOut?.longitude}
  >
    <a class="back-link" href="/">Back to today&apos;s board</a>

    {riverHubHref ? (
      <p class="river-detail__group-link">
        <a href={riverHubHref}>See all {siblingRoutes.length + 1} routes on {river.name}</a>
      </p>
    ) : null}

    <div class="river-detail__layout">
      <nav class="river-detail__section-nav river-detail__section-nav--desktop" aria-label="River page chapters">
        <div class="river-detail__section-nav-inner">
          <p class="river-detail__section-nav-label">Chapters</p>
          <a class="river-detail__section-link" href="#todays-score" data-detail-nav-link="today" data-detail-nav-target="todays-score">
            Today
          </a>
          <a class="river-detail__section-link" href="#access-plan" data-detail-nav-link="plan" data-detail-nav-target="access-plan">
            Plan
          </a>
          <a class="river-detail__section-link" href="#why-this-call" data-detail-nav-link="understand" data-detail-nav-target="why-this-call">
            Understand
          </a>
          <a class="river-detail__section-link" href="#share-trip" data-detail-nav-link="contribute" data-detail-nav-target="share-trip">
            Contribute
          </a>
        </div>
      </nav>

      <div class="river-detail__content">
    <section class="river-detail__hero" id="todays-score" data-detail-section="todays-score" data-detail-nav-group="today">
      <div class="river-detail__hero-main">
        <div class="river-detail__hero-warning" data-live-warning-wrap hidden>
          <span class="pill pill--warning" data-field="live-warning" hidden></span>
        </div>

        <div class="river-detail__hero-top">
          <div class="river-detail__hero-title-block">
            <p class="eyebrow">{river.state} | {river.region}</p>
            <h1 class="river-detail__title">{river.name}</h1>
            <p class="river-detail__reach">{river.reach}</p>
          </div>
        </div>

        <p class="river-detail__summary" data-field="explanation">
          Loading today&apos;s river score.
        </p>

        <div class="river-detail__meta-row">
          <span class="pill" data-field="decision">Checking</span>
          <a
            class="pill river-detail__jump-pill"
            href="#why-this-call"
            data-field="confidence"
            data-detail-jump="why-this-call"
            data-detail-expand="confidence"
          >
            Checking support
          </a>
          <span class="pill" data-field="data-status">Checking reads</span>
          <span class="pill">{river.statusText}</span>
        </div>

        <div class="river-detail__hero-map-shell" data-detail-hero-map-shell>
          <div class="river-detail__hero-map-frame">
            <div class="river-detail__hero-map" data-detail-hero-map aria-label={`${river.name} route snapshot map`}></div>
            <div class="river-detail__hero-map-copy">
              <p class="river-detail__hero-map-label">Route snapshot</p>
              <p class="river-detail__hero-map-status muted" data-detail-hero-map-status>
                Loading mapped route.
              </p>
            </div>
          </div>
        </div>

      </div>
      <div class="river-detail__hero-side river-detail__hero-side--sticky">
      <section class="route-action-bar route-action-bar--rail" aria-label="Route actions">
        <div class="route-action-bar__row">
          <button class="route-action-button route-action-button--primary" type="button" data-alert-open>
            <span class="route-action-button__icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" focusable="false">
                <path
                  d="M12 22a2.6 2.6 0 0 1-2.43-1.69h4.86A2.6 2.6 0 0 1 12 22Zm7-3.25H5v-1.5l1.65-1.48v-4.11a5.35 5.35 0 0 1 4.1-5.23V5.6a1.25 1.25 0 1 1 2.5 0v.83a5.35 5.35 0 0 1 4.1 5.23v4.11L19 17.25v1.5Z"
                  fill="currentColor"
                />
              </svg>
            </span>
            <span class="route-action-button__label">Alerts</span>
          </button>

          <button
            class="route-action-button route-action-button--save"
            type="button"
            data-favorite-button
            data-favorite-slug={river.slug}
            data-favorite-name={river.name}
            data-favorite-reach={river.reach}
            data-favorite-state={river.state}
            data-favorite-region={river.region}
            data-favorite-url={`/rivers/${river.slug}/`}
            data-unsaved-label="Save"
            data-saved-label="Saved"
          >
            <span class="route-action-button__icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" focusable="false">
                <path d={FAVORITE_STAR_PATH} />
              </svg>
            </span>
            <span class="route-action-button__label route-action-button__label--desktop" data-favorite-label>Save</span>
          </button>

          <details class="route-action-menu route-action-menu--share" data-route-action-menu>
            <summary class="route-action-button route-action-button--menu" aria-label="Share route">
              <span class="route-action-button__icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" focusable="false">
                  <path
                    d="M14 4h6v6h-1.8V7.07l-7.01 7.01-1.27-1.27 7.01-7.01H14V4Zm-8 2h5v1.8H6.9v9.3h9.3V13H18v5a1 1 0 0 1-1 1H6a1 1 0 0 1-1-1V7a1 1 0 0 1 1-1Z"
                    fill="currentColor"
                  />
                </svg>
              </span>
              <span class="route-action-button__label route-action-button__label--desktop">Share</span>
            </summary>
            <div class="route-action-menu__panel">
              <a
                class="route-action-menu__item route-action-button--x"
                href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(routeShareText)}&url=${encodeURIComponent(routeUrl)}`}
                target="_blank"
                rel="noreferrer"
                data-share-x
              >
                <span class="route-action-button__icon" aria-hidden="true">
                  <svg viewBox="0 0 24 24" focusable="false">
                    <path
                      d="M17.94 3H21l-6.7 7.66L22.18 21h-6.2l-4.86-6.35L5.56 21H2.5l7.17-8.19L2.18 3h6.36l4.4 5.77L17.94 3Zm-1.09 16.12h1.7L7.61 4.79H5.79l11.06 14.33Z"
                      fill="currentColor"
                    />
                  </svg>
                </span>
                <span>X</span>
              </a>
              <a
                class="route-action-menu__item route-action-button--facebook"
                href={`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(routeUrl)}`}
                target="_blank"
                rel="noreferrer"
                data-share-facebook
              >
                <span class="route-action-button__icon" aria-hidden="true">
                  <svg viewBox="0 0 24 24" focusable="false">
                    <path
                      d="M13.52 21v-7.8h2.62l.39-3.05h-3.01V8.2c0-.88.24-1.49 1.5-1.49h1.6V4a21.8 21.8 0 0 0-2.34-.12c-2.31 0-3.89 1.41-3.89 4v2.27H7.77v3.05h2.62V21h3.13Z"
                      fill="currentColor"
                    />
                  </svg>
                </span>
                <span>Facebook</span>
              </a>
              <button class="route-action-menu__item" type="button" data-share-copy>
                <span class="route-action-button__icon" aria-hidden="true">
                  <svg viewBox="0 0 24 24" focusable="false">
                    <path
                      d="M14.7 6.3a3.75 3.75 0 0 1 5.3 5.3l-2.4 2.4a3.75 3.75 0 0 1-5.3 0l-.35-.35 1.41-1.41.35.35a1.75 1.75 0 0 0 2.48 0l2.4-2.4a1.75 1.75 0 1 0-2.48-2.48l-1.55 1.55-1.41-1.41 1.55-1.55Zm-5.4 11.4a3.75 3.75 0 0 1-5.3-5.3l2.4-2.4a3.75 3.75 0 0 1 5.3 0l.35.35-1.41 1.41-.35-.35a1.75 1.75 0 0 0-2.48 0l-2.4 2.4a1.75 1.75 0 0 0 2.48 2.48l1.55-1.55 1.41 1.41-1.55 1.55Zm6.46-8.57 1.41 1.41-8.48 8.48-1.41-1.41 8.48-8.48Z"
                      fill="currentColor"
                    />
                  </svg>
                </span>
                <span>Copy link</span>
              </button>
            </div>
          </details>

        </div>

      </section>
      <aside class="river-call-panel">
        <p class="eyebrow">Today&apos;s score</p>
        <div class="score-orb score-orb--featured" aria-label="Live score loading">
          <span class="score-orb__score" data-field="score">--</span>
          <span class="score-orb__rating" data-field="rating">Checking</span>
        </div>
        <p class="river-call-panel__statement" data-field="decision-line">
          Loading the current river read.
        </p>
        <details class="river-score-tooltip">
          <summary class="river-score-tooltip__summary">
            <span>Why this score</span>
          </summary>
          <div class="river-score-tooltip__panel">
            <p class="muted river-score-tooltip__intro" data-field="breakdown-summary">
              Checking how today&apos;s score comes together.
            </p>

            <div class="river-score-tooltip__rows">
              <article class="river-score-tooltip__row">
                <span class="river-score-tooltip__label">River quality</span>
                <strong class="river-score-tooltip__value river-score-breakdown__row-value--positive" data-field="breakdown-river-quality">
                  Checking
                </strong>
              </article>
              <article class="river-score-tooltip__row">
                <span class="river-score-tooltip__label">Wind</span>
                <strong class="river-score-tooltip__value" data-field="breakdown-wind-adjustment">Checking</strong>
              </article>
              <article class="river-score-tooltip__row">
                <span class="river-score-tooltip__label">Temperature</span>
                <strong class="river-score-tooltip__value" data-field="breakdown-temperature-adjustment">Checking</strong>
              </article>
              <article class="river-score-tooltip__row">
                <span class="river-score-tooltip__label">Rain timing</span>
                <strong class="river-score-tooltip__value" data-field="breakdown-rain-adjustment">Checking</strong>
              </article>
              <article class="river-score-tooltip__row" data-breakdown-other-group hidden>
                <span class="river-score-tooltip__label">Other</span>
                <strong class="river-score-tooltip__value" data-field="breakdown-comfort-adjustment">Checking</strong>
              </article>
            </div>

            <div class="river-score-tooltip__caps" data-score-cap-wrap hidden>
              <p class="river-score-tooltip__caps-label">What limited today&apos;s score</p>
              <ul class="compact-list river-score-tooltip__caps-list" data-score-cap-reasons>
                <li>Checking what limited today&apos;s score.</li>
              </ul>
            </div>
          </div>
        </details>
        <div class="river-call-panel__reliability">
          <span class="pill" data-field="rail-reliability">Checking reads</span>
          <p class="muted river-call-panel__reliability-note" data-field="rail-next-step">
            Loading source and freshness details.
          </p>
        </div>
          <dl class="river-call-panel__meta">
            <div>
            <dt>Latest live read</dt>
              <dd data-field="observed-at">Checking</dd>
            </div>
            <div>
            <dt>Paddle Today updated</dt>
              <dd data-field="generated-at">Checking</dd>
            </div>
          </dl>
        <div class="river-call-panel__actions">
          <button class="filter-chip" type="button" data-detail-refresh>
            Refresh river
          </button>
          <span class="muted river-call-panel__refresh-note" data-detail-refresh-note>
            Auto-refreshes every 5 minutes.
          </span>
        </div>
        <a
          class="river-link river-link--wide"
          href={river.profile.thresholdSource.url}
          target="_blank"
          rel="noreferrer"
        >
          See source behind this score
        </a>
      </aside>
      </div>
      </section>

      <dialog class="route-alert-dialog" data-alert-dialog aria-label="River alert signup">
        <form method="dialog" class="route-alert-dialog__shell">
          <button class="route-alert-dialog__close" type="submit" value="cancel" aria-label="Close alert dialog">
            Close
          </button>
        </form>

        <div class="route-alert-dialog__body">
          <p class="eyebrow">Route alerts</p>
          <h2 class="river-alerts__title">Email me when this route improves</h2>
          <p class="muted river-alerts__copy">
            Threshold alerts only. We email you when this route climbs into Good or Strong, and every email includes an unsubscribe link.
          </p>

          <form class="river-alerts__form" data-alert-form novalidate>
            <label class="river-alerts__field">
              <span class="sr-only">Email address for river alerts</span>
              <input
                class="river-alerts__input"
                type="email"
                name="email"
                placeholder="you@example.com"
                autocomplete="email"
                data-alert-email
              />
            </label>
            <div class="river-alerts__actions">
              <button class="filter-chip filter-chip--primary" type="submit" data-alert-submit="good">
                Notify at Good
              </button>
              <button class="filter-chip" type="submit" data-alert-submit="strong">
                Notify at Strong
              </button>
            </div>
            <input type="text" name="company" tabindex="-1" autocomplete="off" hidden data-alert-company />
            <p class="river-alerts__status muted" data-alert-status aria-live="polite">
              No spam. We only email on a new threshold crossing.
            </p>
          </form>
        </div>
      </dialog>

      <nav class="river-detail__section-nav river-detail__section-nav--mobile" aria-label="River page chapters">
        <div class="river-detail__section-nav-inner">
        <p class="river-detail__section-nav-label">Chapters</p>
        <a class="river-detail__section-link" href="#todays-score" data-detail-nav-link="today" data-detail-nav-target="todays-score">
          Today
        </a>
        <a class="river-detail__section-link" href="#access-plan" data-detail-nav-link="plan" data-detail-nav-target="access-plan">
          Plan
        </a>
        <a class="river-detail__section-link" href="#why-this-call" data-detail-nav-link="understand" data-detail-nav-target="why-this-call">
          Understand
        </a>
        <a class="river-detail__section-link" href="#share-trip" data-detail-nav-link="contribute" data-detail-nav-target="share-trip">
          Contribute
        </a>
      </div>
    </nav>

    <section class="status-banner status-banner--offline status-banner--hidden" data-detail-fetch-banner aria-live="polite">
      <div class="status-banner__eyebrow">Refresh failed</div>
      <div class="status-banner__body">
        <strong data-detail-fetch-title>Live inputs could not be refreshed.</strong>
        <p class="muted" data-detail-fetch-detail>
          This river score may be stale. Retry before you drive.
        </p>
      </div>
    </section>

    <section class="status-banner status-banner--loading" data-detail-status-banner aria-live="polite">
      <div class="status-banner__eyebrow">Read quality</div>
      <div class="status-banner__body">
        <strong data-detail-banner-title>Checking live inputs.</strong>
        <p class="muted" data-detail-banner-detail>
          Loading the latest river read.
        </p>
      </div>
      <div class="status-banner__grid" data-detail-reliability-grid>
        <article class="status-banner__item">
          <span class="status-banner__label">Gauge input</span>
