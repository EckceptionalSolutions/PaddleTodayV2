      </p>
      <div class="river-launch-plan__hero">
        <div class="river-launch-plan__copy">
          <h2 class="river-subtitle">Access, shuttle, and map</h2>
          <p class="muted">
            {logistics?.summary ??
              'Use the links below to confirm launch, shuttle, and access rules.'}
          </p>
          <div class="detail-map__links detail-map__links--primary">
            {directionsGoogleUrl ? (
              <a
                class="river-link river-link--inline river-link--primary"
                href={directionsGoogleUrl}
                target="_blank"
                rel="noreferrer"
                data-access-directions-google
                data-analytics-event="Open route directions"
                data-analytics-label="google"
              >
                Directions
              </a>
            ) : null}
            {directionsAppleUrl ? (
              <a
                class="river-link river-link--inline"
                href={directionsAppleUrl}
                target="_blank"
                rel="noreferrer"
                data-access-directions-apple
                data-analytics-event="Open route directions"
                data-analytics-label="apple"
              >
                Apple Maps
              </a>
            ) : null}
            <a
              class="river-link river-link--inline"
              href={openStreetMapUrl}
              target="_blank"
              rel="noreferrer"
              data-access-openstreetmap
              data-analytics-event="Open route map"
              data-analytics-label="openstreetmap"
            >
              OpenStreetMap
            </a>
          </div>
        </div>
      </div>

      {hasAccessPlanner ? (
        <section class="river-access-planner" data-access-planner>
          <div class="river-why-panel__section-head">
            <div>
              <p class="eyebrow section-label">
                <FeatureIcon name="map" size={16} />
                Access planner
              </p>
              <h3 class="river-subtitle river-subtitle--compact">Pick a shorter segment</h3>
            </div>
            <p class="muted river-why-panel__section-note">
              This changes launch and take-out logistics, not today&apos;s river score.
            </p>
          </div>

          <div class="river-access-planner__controls">
            <label class="river-access-planner__field">
              <span class="snapshot-card__label">Put-in</span>
              <select data-access-putin>
                {(river.accessPoints ?? []).map((point, index) => (
                  <option value={point.id} selected={index === 0}>{point.name}</option>
                ))}
              </select>
            </label>
            <label class="river-access-planner__field">
              <span class="snapshot-card__label">Take-out</span>
              <select data-access-takeout>
                {(river.accessPoints ?? []).map((point, index, points) => (
                  <option value={point.id} selected={index === points.length - 1}>{point.name}</option>
                ))}
              </select>
            </label>
          </div>

          <div class="river-detail__quick-grid river-detail__quick-grid--compact river-access-planner__metrics">
            <article class="snapshot-card">
              <span class="snapshot-card__label">On-water distance</span>
              <strong data-access-distance>{logistics?.distanceLabel ?? '15.2 mi'}</strong>
              <small data-access-shape>Lake to creek</small>
            </article>
            <article class="snapshot-card">
              <span class="snapshot-card__label">On-water time</span>
              <strong data-access-time>About 5 to 7 hr</strong>
              <small data-access-stage>Full route option</small>
            </article>
            <article class="snapshot-card">
              <span class="snapshot-card__label">Shuttle</span>
              <strong data-access-shuttle>Self-shuttle</strong>
              <small data-access-note>Choose a shorter in/out pair for a shorter day.</small>
            </article>
          </div>

          <p class="muted river-access-planner__summary" data-access-summary>
            Peltier Lake to Long Lake is the full route. Shorter access pairs are useful when wind, time, or group energy changes the plan.
          </p>

          <script type="application/json" data-access-points set:html={accessPlannerPointsJson}></script>
        </section>
      ) : null}

      <div class="river-launch-plan__body">
        <div class="river-access-grid">
          <article class="river-access-card river-access-card--put-in">
