---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import FeatureIcon from '../../../components/FeatureIcon.astro';
import { listRiverGroups } from '../../../lib/rivers';
import riverGroupPageScript from '../../../scripts/river-group-page.js?url';

export function getStaticPaths() {
  return listRiverGroups()
    .filter((group) => group.routeCount > 1)
    .map((group) => ({
      params: { riverId: group.riverId },
      props: { group },
    }));
}

const { group } = Astro.props;
const stateSummary = group.states.join(', ');
const regionSummary = group.regions.join(', ');
---

<BaseLayout
  title={`${group.name} | Paddle Today`}
  description={`${group.name}: compare scored routes on the same river and open the best route call for today.`}
>
  <article class="river-group-page" data-river-group-page data-river-id={group.riverId}>
    <a class="back-link" href="/">All river calls</a>

    <section class="river-group-page__hero">
      <div class="river-group-page__hero-main">
        <p class="eyebrow">{stateSummary} | {regionSummary}</p>
        <h1 class="river-group-page__title">{group.name}</h1>
        <p class="river-group-page__lede" data-group-headline>
          Compare {group.routeCount} route calls on this river.
        </p>
        <p class="muted river-group-page__summary" data-group-detail>
          One river can hold very different launch calls. Compare the score, confidence, and summary line before you open full trip details.
        </p>

        <div class="hero__meta river-group-page__meta">
          <span class="stat-chip">{group.routeCount} routes</span>
          <span class="stat-chip">Each route has its own launch call</span>
        </div>
      </div>

      <aside class="river-call-panel river-call-panel--group">
        <p class="eyebrow">Selected route</p>
        <div class="score-orb score-orb--featured" aria-label="Selected route score loading">
          <span class="score-orb__score" data-field="selected-score">--</span>
          <span class="score-orb__rating" data-field="selected-rating">Checking</span>
        </div>
        <p class="river-call-panel__statement" data-field="selected-reach">
          Loading the selected route.
        </p>
        <div class="river-call-panel__reliability river-call-panel__reliability--compact">
          <span class="pill" data-field="selected-status">Checking</span>
          <p class="muted river-call-panel__reliability-note" data-field="selected-confidence">
            Checking confidence.
          </p>
        </div>
        <p class="river-call-panel__summary-line" data-field="selected-summary">
          Summary line will appear once the grouped scores load.
        </p>
        <p class="river-call-panel__signal-line" data-field="selected-signal">
          Data line will appear once the grouped scores load.
        </p>
        <div class="river-call-panel__actions river-call-panel__actions--inline">
          <button class="filter-chip" type="button" data-group-refresh>
            Refresh river
          </button>
          <a class="river-link river-link--wide" href="/" data-group-selected-link>
            View river
          </a>
        </div>
        <p class="muted river-call-panel__refresh-note" data-group-refresh-note>
          Auto-refreshes every 5 minutes.
        </p>
      </aside>
    </section>

    <section class="status-banner status-banner--loading status-banner--compact" data-group-status-banner aria-live="polite">
      <div class="status-banner__eyebrow">Route comparison</div>
      <div class="status-banner__body">
        <strong data-group-banner-title>Checking route calls.</strong>
        <p class="muted" data-group-banner-detail>
          Loading live route comparison for this river.
        </p>
      </div>
    </section>

    <section class="river-group-page__panel river-group-page__panel--map">
      <div class="river-group-page__section-head river-group-page__section-head--map">
        <div>
          <p class="eyebrow section-label">
            <FeatureIcon name="map" size={16} />
            Route map
          </p>
          <h2 class="section-title">Where these routes sit</h2>
        </div>
        <p class="muted river-group-page__section-note">
          All route starts and finishes on one supporting map.
        </p>
      </div>

      <div class="river-group-page__map-shell">
        <div class="river-group-page__map" data-group-map aria-label={`${group.name} route map`}></div>
        <p class="muted river-group-page__map-status" data-group-map-status>
          Loading route map.
        </p>
      </div>
    </section>

    <section class="river-group-page__panel">
      <div class="river-group-page__section-head">
        <div>
          <p class="eyebrow section-label">
            <FeatureIcon name="compass" size={16} />
            Route switcher
          </p>
          <h2 class="section-title">Compare routes on this river</h2>
        </div>
        <p class="muted river-group-page__section-note">
          Same river, different launch calls.
        </p>
      </div>

      <div class="river-group-page__route-list" data-group-route-list>
        {group.routes.map((route) => (
          <button
            class="route-choice"
            type="button"
            data-group-route-button
            data-route-slug={route.slug}
          >
            <span class="route-choice__kind">Route</span>
            <span class="route-choice__eyebrow">{route.state} | {route.region}</span>
            <strong class="route-choice__title">{route.reach}</strong>
            <span class="route-choice__score">-- • Checking</span>
            <span class="route-choice__meta">Checking confidence • -- mi</span>
            <span class="route-choice__summary">Loading summary line.</span>
          </button>
        ))}
      </div>
    </section>
  </article>

  <script type="module" src={riverGroupPageScript}></script>
</BaseLayout>
