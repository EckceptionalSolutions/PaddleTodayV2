---
import BaseLayout from '../layouts/BaseLayout.astro';
import { scoringCalibrationCases } from '../data/scoring-calibrations';
import { rivers } from '../data/rivers';
import { scoreRiverCondition } from '../lib/scoring';

function formatSigned(value: number) {
  return value > 0 ? `+${value}` : String(value);
}

const calibrationResults = scoringCalibrationCases.map((calibrationCase) => {
  const river = rivers.find((item) => item.slug === calibrationCase.routeSlug);
  if (!river) {
    return {
      calibrationCase,
      river: null,
      result: null,
      status: 'Missing route',
    };
  }

  const result = scoreRiverCondition({
    river,
    gauge: calibrationCase.gauge,
    weather: calibrationCase.weather,
    now: new Date(calibrationCase.now),
  });

  const inExpectedBand =
    result.rating === calibrationCase.expected.rating &&
    result.gaugeBand === calibrationCase.expected.gaugeBand &&
    result.score >= calibrationCase.expected.scoreMin &&
    result.score <= calibrationCase.expected.scoreMax;

  return {
    calibrationCase,
    river,
    result,
    status: inExpectedBand ? 'In range' : 'Needs review',
  };
});

const routeAuditGroups = Array.from(
  rivers
    .slice()
    .sort((left, right) =>
      `${left.state} ${left.region} ${left.name} ${left.reach}`.localeCompare(
        `${right.state} ${right.region} ${right.name} ${right.reach}`
      )
    )
    .reduce((groups, river) => {
      const key = `${river.state} / ${river.region}`;
      const items = groups.get(key) ?? [];
      items.push(river);
      groups.set(key, items);
      return groups;
    }, new Map<string, typeof rivers>())
);
---

<BaseLayout
  title="Admin Workspace | Paddle Today"
  description="Review submissions, route requests, alerts, and real-world scoring checks for Paddle Today."
>
  <section class="info-hero admin-review" data-admin-review>
    <p class="eyebrow">Admin</p>
    <h1>Admin workspace</h1>
    <p class="muted">Review submissions, route requests, alerts, and real-world scoring checks.</p>

    <div class="admin-review__login" data-admin-login-panel>
      <form class="admin-review__login-form" data-admin-login-form>
        <label>
          Password
          <input type="password" name="password" autocomplete="current-password" data-admin-password />
        </label>
        <button class="filter-chip" type="submit">Sign in</button>
      </form>
      <p class="muted request-form__status" data-admin-login-status aria-live="polite"></p>
    </div>

    <div class="admin-review__toolbar" data-admin-toolbar hidden>
      <div class="admin-review__toolbar-row">
        <label>
          Contributions
          <select data-admin-status-filter>
            <option value="pending">Pending</option>
            <option value="approved">Approved</option>
            <option value="rejected">Rejected</option>
            <option value="all">All</option>
          </select>
        </label>
        <label>
          Type
          <select data-admin-type-filter>
            <option value="all">All</option>
            <option value="photo">Photos only</option>
            <option value="report">Reports only</option>
            <option value="mixed">Photos + report</option>
          </select>
        </label>
        <button class="river-inline-button" type="button" data-admin-refresh>Refresh</button>
        <button class="river-inline-button" type="button" data-admin-logout>Sign out</button>
      </div>
      <p class="muted request-form__status" data-admin-toolbar-status aria-live="polite"></p>
    </div>

    <nav class="admin-section-nav" aria-label="Admin sections" data-admin-section-nav hidden>
      <a href="#admin-submissions">Submissions</a>
      <a href="#admin-requests">Requests</a>
      <a href="#admin-alerts">Alerts</a>
      <a href="#admin-route-audits">Route audits</a>
      <a href="#admin-reality-checks">Reality checks</a>
    </nav>
  </section>

  <section class="admin-review__stats" id="admin-alerts" data-admin-stats hidden>
    <article class="snapshot-card">
      <span class="snapshot-card__label">Active alerts</span>
      <strong data-admin-alert-active>0</strong>
      <small data-admin-alert-total>0 total alerts</small>
      <small data-admin-alert-latest>Latest check unknown</small>
    </article>
    <article class="snapshot-card">
      <span class="snapshot-card__label">Strong alerts</span>
      <strong data-admin-alert-strong>0</strong>
      <small data-admin-alert-good>0 Good alerts</small>
      <small data-admin-alert-never>0 never evaluated</small>
    </article>
    <article class="snapshot-card">
      <span class="snapshot-card__label">Rivers covered</span>
      <strong data-admin-alert-rivers>0</strong>
      <small>Active alert coverage</small>
      <small data-admin-alert-stalest>Oldest check unknown</small>
    </article>
  </section>

  <section class="admin-route-audits" id="admin-route-audits" data-admin-route-audits hidden>
    <div class="admin-review__section-head">
      <div>
        <p class="eyebrow">Route audits</p>
        <h2>Human quality audit checklist</h2>
      </div>
      <p class="muted request-form__status" data-admin-route-audits-status aria-live="polite"></p>
    </div>

    <div class="admin-route-audits__stats">
      <article class="snapshot-card">
        <span class="snapshot-card__label">Total routes</span>
        <strong data-admin-route-audits-total>{rivers.length}</strong>
        <small>Routes currently in the app</small>
      </article>
      <article class="snapshot-card">
        <span class="snapshot-card__label">Audited</span>
        <strong data-admin-route-audits-complete>0</strong>
        <small>Marked human quality audited</small>
      </article>
      <article class="snapshot-card">
        <span class="snapshot-card__label">Remaining</span>
        <strong data-admin-route-audits-remaining>{rivers.length}</strong>
        <small>Still needs review</small>
      </article>
    </div>

    <div class="admin-route-audits__groups" data-admin-route-audit-list>
      {routeAuditGroups.map(([groupLabel, groupRivers]) => (
        <section class="admin-route-audit-group" aria-labelledby={`route-audit-${groupLabel.replace(/[^a-zA-Z0-9]+/g, '-').toLowerCase()}`}>
          <h3 id={`route-audit-${groupLabel.replace(/[^a-zA-Z0-9]+/g, '-').toLowerCase()}`}>{groupLabel}</h3>
          <div class="admin-route-audit-group__list">
            {groupRivers.map((river) => (
              <article class="admin-route-audit-row" data-route-audit-row data-route-slug={river.slug}>
                <label class="admin-route-audit-row__check">
                  <input type="checkbox" data-admin-route-audit-toggle />
                  <span aria-hidden="true"></span>
                </label>
                <div class="admin-route-audit-row__main">
                  <div>
                    <h4>{river.name}</h4>
                    <p class="muted">{river.reach}</p>
                  </div>
                  <div class="admin-route-audit-row__meta">
                    <span>{river.profile.difficulty}</span>
                    <span>{river.profile.thresholdSourceStrength}</span>
                    <a href={`/rivers/${river.slug}`}>Open route</a>
                  </div>
                </div>
                <label class="admin-route-audit-row__notes">
                  Notes
                  <input type="text" maxlength="600" data-admin-route-audit-notes placeholder="Audit notes" />
                </label>
                <button class="river-inline-button" type="button" data-admin-route-audit-save>Save notes</button>
                <p class="muted admin-route-audit-row__status" data-admin-route-audit-status>Not audited</p>
              </article>
            ))}
          </div>
        </section>
      ))}
    </div>
  </section>

  <section class="admin-scoring-debug" id="admin-reality-checks" data-admin-scoring-debug hidden>
    <div class="admin-review__section-head">
      <div>
        <p class="eyebrow">Reality checks</p>
        <h2>Real paddles vs app verdicts</h2>
      </div>
      <p class="muted">Use known on-water examples to tune scoring without losing real-world context.</p>
    </div>

    <div class="admin-scoring-debug__list">
      {calibrationResults.map(({ calibrationCase, river, result, status }) => (
        <article class={`admin-scoring-card admin-scoring-card--${status === 'In range' ? 'ok' : 'review'}`}>
          <header class="admin-scoring-card__head">
            <div>
              <p class="eyebrow">{calibrationCase.paddledOn}</p>
              <h3>{calibrationCase.label}</h3>
              <p class="muted">{river ? `${river.name} / ${river.reach}` : calibrationCase.routeSlug}</p>
            </div>
            <span class="admin-scoring-card__status">{status}</span>
          </header>

          {result ? (
            <>
              <div class="admin-scoring-card__metrics">
                <div>
                  <span>Current app</span>
                  <strong>{result.score} {result.rating}</strong>
                </div>
                <div>
                  <span>Expected</span>
                  <strong>{calibrationCase.expected.scoreMin}-{calibrationCase.expected.scoreMax} {calibrationCase.expected.rating}</strong>
                </div>
                <div>
                  <span>Previous app</span>
                  <strong>{calibrationCase.previousAppScore ? `${calibrationCase.previousAppScore.score} ${calibrationCase.previousAppScore.rating}` : 'None'}</strong>
                </div>
                <div>
                  <span>Gauge band</span>
                  <strong>{result.gaugeBandLabel}</strong>
                </div>
              </div>

              <div class="admin-scoring-card__breakdown">
                <span>River {result.scoreBreakdown.riverQuality}</span>
                <span>Wind {formatSigned(result.scoreBreakdown.windAdjustment)}</span>
                <span>Temp {formatSigned(result.scoreBreakdown.temperatureAdjustment)}</span>
                <span>Rain {formatSigned(result.scoreBreakdown.rainAdjustment)}</span>
                <span>Comfort {formatSigned(result.scoreBreakdown.comfortAdjustment)}</span>
                <span>Raw {result.scoreBreakdown.rawTripScore}</span>
              </div>

              <p class="admin-scoring-card__verdict"><strong>Observed:</strong> {calibrationCase.observedVerdict}</p>
              <ul>
                {calibrationCase.observedNotes.map((note) => <li>{note}</li>)}
              </ul>
              <p class="muted">{result.scoreBreakdown.riverQualityExplanation}</p>
              {result.scoreBreakdown.capReasons.length > 0 && (
                <p class="muted"><strong>Caps:</strong> {result.scoreBreakdown.capReasons.join(' ')}</p>
              )}
            </>
          ) : (
            <p class="muted">This fixture cannot run until the route slug is fixed.</p>
          )}
        </article>
      ))}
    </div>
  </section>

  <section class="admin-review__list" id="admin-submissions" data-admin-submission-list hidden>
    <div class="admin-review__section-head">
      <div>
        <p class="eyebrow">Submissions</p>
        <h2>Trip reports and photo uploads</h2>
      </div>
    </div>
    <div class="admin-review__empty" data-admin-empty hidden>
      <h2>No submissions in this view</h2>
      <p class="muted">Once paddlers start sending trip reports and photos, they�ll show up here.</p>
    </div>
  </section>

  <section class="admin-review__requests" id="admin-requests" data-admin-route-requests hidden>
    <div class="admin-review__section-head">
      <div>
        <p class="eyebrow">Requests</p>
        <h2>Route requests</h2>
      </div>
      <p class="muted request-form__status" data-admin-route-requests-status aria-live="polite"></p>
    </div>
    <div class="admin-review__request-list" data-admin-route-requests-list></div>
  </section>

  <script>
    import '../scripts/admin-contributions-page.js';
  </script>
</BaseLayout>
