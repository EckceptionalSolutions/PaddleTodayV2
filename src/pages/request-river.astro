---
import BaseLayout from '../layouts/BaseLayout.astro';

const requestEmail = 'hello@paddletoday.com';
---

<BaseLayout
  title="Request A Route | Paddle Today"
  description="Request a route for Paddle Today to review. A river name and state are enough to get it on the list."
>
  <section class="info-hero">
    <p class="eyebrow" data-request-kicker>Request a route</p>
    <h1 data-request-title>Request a river or route.</h1>
    <p class="muted" data-request-lede>
      A name and state are enough. Put-in, take-out, gauge, or local notes help us review it faster, but you do not need to have all of that ready.
    </p>
  </section>

  <section class="request-layout request-layout--single">
    <article class="request-card">
      <p class="eyebrow">Request form</p>
      <h2 data-request-form-title>Start with the basics</h2>
      <p class="muted" data-request-form-note>
        Send the river or route you want tracked. If you only know the river, leave the rest blank.
      </p>

      <form class="request-form" data-request-form novalidate>
        <label>
          River or route name *
          <input
            name="routeName"
            required
            minlength="3"
            placeholder="Example: St. Croix River - Taylors Falls to Osceola"
          />
        </label>

        <label>
          State *
          <input name="state" required placeholder="MN, WI, IA, etc." maxlength="32" autocomplete="address-level1" />
        </label>

        <details class="request-form__optional">
          <summary class="request-form__optional-title">Optional details</summary>
          <p class="request-form__hint">These help us review the route faster. Leave anything blank if you are not sure.</p>

          <label>
            Put-in name
            <input name="putIn" placeholder="Launch or access name" />
          </label>

          <label>
            Take-out name
            <input name="takeOut" placeholder="Exit or access name" />
          </label>

          <label>
            Useful links
            <span class="request-form__hint">USGS, DNR, park, club, outfitter, or map links all help.</span>
            <textarea name="sources" rows="3" placeholder="Paste any links you already have"></textarea>
          </label>

          <label>
            Anything else?
            <span class="request-form__hint" id="request-notes-hint">Distance, difficulty, hazards, shuttle notes, or why you want this route.</span>
            <textarea
              name="notes"
              rows="4"
              aria-describedby="request-notes-hint"
              placeholder="Share whatever you know. A sentence is plenty."
            ></textarea>
          </label>
        </details>

        <label>
          Your email (optional)
          <input name="replyEmail" type="email" placeholder="you@example.com" autocomplete="email" />
        </label>

        <label class="request-form__hp" aria-hidden="true">
          Leave this blank
          <input name="company" tabindex="-1" autocomplete="off" />
        </label>

        <div class="request-form__actions">
          <button class="filter-chip" type="submit" data-request-submit>Send request</button>
          <a
            class="river-link river-link--inline"
            href={`mailto:${requestEmail}`}
            data-request-email-link
            data-analytics-event="Open request email"
          >
            Email instead
          </a>
        </div>

        <p class="muted request-form__status" data-request-status aria-live="polite"></p>
      </form>
    </article>
  </section>

  <script>
    import '../scripts/request-page.js';
  </script>
</BaseLayout>
