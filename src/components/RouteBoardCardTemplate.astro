---
import FavoriteButton from './FavoriteButton.astro';
---

<template data-river-card-template>
  <article class="river-card river-card--decision">
    <div class="river-card__eyebrow-row">
      <div class="river-card__eyebrow-meta">
        <span class="river-card__kind" data-field="card-kind"></span>
        <span class="river-card__slot" data-field="card-slot"></span>
        <p class="river-card__state" data-field="state"></p>
      </div>
      <FavoriteButton className="favorite-toggle favorite-toggle--card" hidden />
    </div>

    <div class="river-card__top">
      <div class="river-card__title-block">
        <h3 class="river-card__title">
          <a class="title-link" href="/" data-field="card-title-link"></a>
        </h3>
        <p class="river-card__subtitle" data-field="route-label"></p>
      </div>
      <span class="river-card__warning" data-field="card-warning" hidden></span>
    </div>

    <p class="river-card__verdict" data-field="card-verdict"></p>
    <div class="river-card__scoreline">
      <div class="score-orb" aria-label="Route score">
        <span class="score-orb__score" data-field="score"></span>
        <span class="score-orb__rating" data-field="rating"></span>
      </div>
      <div class="river-card__score-copy">
        <p class="river-card__meta-line" data-field="meta-line"></p>
        <div class="river-card__weather" data-field="card-weather" hidden></div>
        <div class="river-card__signal-line river-card__signal-line--score" data-field="raw-signal"></div>
      </div>
    </div>
    <p class="river-card__explanation" data-field="card-summary-main"></p>
    <section class="river-card__facts-section" data-field="card-facts-section" hidden>
      <p class="river-card__facts-label">Route facts</p>
      <div class="river-card__facts" data-field="card-facts"></div>
    </section>

    <a class="river-link river-link--wide" href="/" data-card-link>View route</a>
  </article>
</template>
