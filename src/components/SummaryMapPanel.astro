---
import FeatureIcon from './FeatureIcon.astro';

const {
  id,
  mode = 'explore',
  className = '',
  mobileLayout = 'collapse',
  eyebrow = 'Score map',
  title,
  lede = '',
  showResults = true,
  resultsTitle = 'Shown on map',
  note = 'Loading routes.',
  status = 'Loading map.',
  ariaLabel = 'Route score map',
  itemNounSingular = 'river',
  itemNounPlural = 'rivers',
} = Astro.props;

const shellClass = [mode === 'nearby' ? 'summary-map-shell summary-map-shell--nearby' : 'summary-map-shell', className]
  .filter(Boolean)
  .join(' ');
---

<section
  class={shellClass}
  id={id}
  data-summary-map-shell
  data-summary-map-mode={mode}
  data-summary-map-mobile-layout={mobileLayout}
  data-summary-map-item-singular={itemNounSingular}
  data-summary-map-item-plural={itemNounPlural}
>
  {mobileLayout === 'list-map' && (
    <div class="summary-map-mobile-switch" data-summary-map-mobile-switch hidden>
      <button
        class="summary-map-mobile-switch__button"
        type="button"
        data-summary-map-mobile-view="list"
        aria-pressed="true"
      >
        List
      </button>
      <button
        class="summary-map-mobile-switch__button"
        type="button"
        data-summary-map-mobile-view="map"
        aria-pressed="false"
      >
        Map
      </button>
    </div>
  )}
  <div class="summary-map-copy">
    <div class="summary-map-copy__intro">
      <p class="eyebrow section-label">
        <FeatureIcon name="map" size={16} />
        {eyebrow}
      </p>
      <h2 class="section-title">{title}</h2>
      {lede && <p class="muted summary-map-copy__lede">{lede}</p>}
    </div>
    {showResults && (
      <div class="summary-map-results-panel" data-summary-map-results-panel>
        <div class="summary-map-results-head">
          <div class="summary-map-results-head__row">
            <p
              class="summary-map-results__title"
              data-summary-map-results-title
              data-default-label={resultsTitle}
              data-mobile-map-label="Map shortlist"
            >
              {resultsTitle}
            </p>
            <button
              class="filter-chip filter-chip--quiet summary-map-results__back"
              type="button"
              data-summary-map-mobile-back
              hidden
            >
              Back to list
            </button>
          </div>
          <p class="muted summary-map-results__note" data-summary-map-results-note>{note}</p>
        </div>
        <div class="summary-map-results" data-summary-map-results aria-live="polite"></div>
      </div>
    )}
    <button class="filter-chip summary-map__toggle" type="button" data-summary-map-toggle hidden aria-expanded="true">Hide map</button>
  </div>

  <div class="summary-map-frame">
    <div class="summary-map" data-summary-map aria-label={ariaLabel}></div>
    <div class="summary-map-footer">
      <p class="summary-map__status muted" data-summary-map-status>{status}</p>
      <div class="summary-map-legend" aria-label="Score map legend">
        <span class="summary-map-legend__item">
          <span class="summary-map-legend__marker summary-map-legend__marker--great">90</span>
          Great
        </span>
        <span class="summary-map-legend__item">
          <span class="summary-map-legend__marker summary-map-legend__marker--good">70</span>
          Good
        </span>
        <span class="summary-map-legend__item">
          <span class="summary-map-legend__marker summary-map-legend__marker--marginal">55</span>
          Fair
        </span>
        <span class="summary-map-legend__item">
          <span class="score-map-marker score-map-marker--no-go score-map-marker--confidence-low">15</span>
          No-go
        </span>
      </div>
    </div>
  </div>
</section>
