---
import FeatureIcon from '../components/FeatureIcon.astro';
import { listRiverGroups, listRivers } from '../lib/rivers';

type Props = {
  title: string;
  description?: string;
  noindex?: boolean;
  structuredData?: Record<string, unknown> | Array<Record<string, unknown>>;
  socialTitle?: string;
  socialDescription?: string;
  socialImage?: string;
  socialImageAlt?: string;
  socialImageWidth?: number;
  socialImageHeight?: number;
  ogType?: string;
  twitterCard?: 'summary' | 'summary_large_image';
};

const {
  title,
  description = 'Live river scores, confidence, and explanations for paddlers.',
  noindex = false,
  structuredData,
  socialTitle = title,
  socialDescription = description,
  socialImage: socialImageProp,
  socialImageAlt = 'Paddle Today social preview',
  socialImageWidth,
  socialImageHeight,
  ogType = 'website',
  twitterCard = 'summary_large_image',
} =
  Astro.props as Props;
const canonicalUrl = Astro.site ? new URL(Astro.url.pathname, Astro.site).href : Astro.url.href;
const socialImage = socialImageProp
  ? Astro.site
    ? new URL(socialImageProp, Astro.site).href
    : socialImageProp
  : Astro.site
    ? new URL('/brand/paddle-today-share-card-v2-1200x630.png', Astro.site).href
    : undefined;
const siteUrl = Astro.site ? Astro.site.href : `${Astro.url.origin}/`;
const organizationId = new URL('/#organization', siteUrl).href;
const websiteId = new URL('/#website', siteUrl).href;
const defaultStructuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    '@id': organizationId,
    name: 'Paddle Today',
    url: new URL('/', siteUrl).href,
    logo: socialImage,
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    '@id': `${canonicalUrl}#webpage`,
    name: title,
    description,
    url: canonicalUrl,
    isPartOf: {
      '@id': websiteId,
    },
    about: {
      '@id': organizationId,
    },
  },
];
const extraStructuredData = structuredData
  ? Array.isArray(structuredData)
    ? structuredData
    : [structuredData]
  : [];
const structuredDataJson = JSON.stringify([...defaultStructuredData, ...extraStructuredData]);
const searchRouteItems = listRivers()
  .map((river) => ({
    kind: 'route',
    kindLabel: 'Route',
    title: river.name,
    subtitle: river.reach,
    meta: [river.region, river.state].filter(Boolean).join(' / '),
    href: `/rivers/${river.slug}/`,
    searchText: [river.name, river.reach, ...(river.aliases ?? []), river.region, river.state].filter(Boolean).join(' '),
  }))
  .sort((left, right) => left.title.localeCompare(right.title));
const searchRiverItems = listRiverGroups()
  .map((group) => ({
    kind: 'river',
    kindLabel: 'River',
    title: group.name,
    subtitle: `${group.routeCount} ${group.routeCount === 1 ? 'route' : 'routes'}`,
    meta: group.states.join(' / '),
    href:
      group.routeCount > 1
        ? `/rivers/by-river/${group.riverId}/`
        : `/rivers/${group.routes[0]?.slug ?? group.riverId}/`,
    searchText: [
      group.name,
      ...group.states,
      ...group.regions,
      ...group.routes.map((route) => route.reach),
      ...group.routes.flatMap((route) => route.aliases ?? []),
    ]
      .filter(Boolean)
      .join(' '),
  }))
  .sort((left, right) => left.title.localeCompare(right.title));
const searchIndexJson = JSON.stringify([...searchRiverItems, ...searchRouteItems]);
const pageClass =
  Astro.url.pathname === '/'
    ? 'page-home'
    : `page-${Astro.url.pathname
        .replace(/^\/+|\/+$/g, '')
        .replace(/[^a-zA-Z0-9/_-]+/g, '')
        .replace(/[\\/]+/g, '-')
        .toLowerCase() || 'page'}`;
const plausibleDomain = import.meta.env.PUBLIC_PLAUSIBLE_DOMAIN;
const plausibleScriptSrc = import.meta.env.PUBLIC_PLAUSIBLE_SCRIPT_SRC || 'https://plausible.io/js/script.js';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow'} />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="Paddle Today" />
    <meta property="og:title" content={socialTitle} />
    <meta property="og:description" content={socialDescription} />
    <meta property="og:url" content={canonicalUrl} />
    {socialImage && <meta property="og:image" content={socialImage} />}
    {socialImage && <meta property="og:image:alt" content={socialImageAlt} />}
    {socialImageWidth && <meta property="og:image:width" content={String(socialImageWidth)} />}
    {socialImageHeight && <meta property="og:image:height" content={String(socialImageHeight)} />}
    <meta name="twitter:card" content={twitterCard} />
    <meta name="twitter:title" content={socialTitle} />
    <meta name="twitter:description" content={socialDescription} />
    {socialImage && <meta name="twitter:image" content={socialImage} />}
    {socialImage && <meta name="twitter:image:alt" content={socialImageAlt} />}
    {
      plausibleDomain && (
        <>
          <script
            is:inline
            set:html={`window.plausible=window.plausible||function(){(window.plausible.q=window.plausible.q||[]).push(arguments)}`}
          />
          <script defer data-domain={plausibleDomain} src={plausibleScriptSrc}></script>
        </>
      )
    }
    <script type="application/ld+json" set:html={structuredDataJson}></script>
    <link rel="icon" type="image/png" href="/brand/paddle-today-logo-transparent-512.png" />
    <link rel="shortcut icon" href="/brand/paddle-today-logo-transparent-512.png" />
    <link rel="apple-touch-icon" href="/brand/paddle-today-logo-transparent-512.png" />
    <link rel="stylesheet" href="/global.css" />
  </head>
  <body class={pageClass}>
    <div class="page-shell">
      <header class="site-header">
        <a class="brand" href="/">
          <img
            class="brand__logo"
            src="/brand/paddle-today-logo-transparent-512.png"
            alt="Paddle Today"
          />
          <div class="brand__copy brand__copy--with-wordmark">
            <span class="brand__eyebrow">Paddle Today</span>
            <span class="brand__title">Find the best paddle near you today.</span>
          </div>
        </a>

        <div class="site-header__meta">
          <div class="site-header__topline">
            <nav class="site-header__nav" aria-label="Primary">
              <a class="site-header__nav-link site-header__nav-link--primary" href="/">Today</a>
              <a class="site-header__nav-link site-header__nav-link--primary" href="/weekend/">Weekend</a>
              <a class="site-header__nav-link site-header__nav-link--primary" href="/guides/best-minnesota-paddle-trips/">
                Guides
              </a>
              <a class="site-header__nav-link site-header__nav-link--primary" href="/explore/">
                <span class="site-header__nav-label site-header__nav-label--full">Browse Routes</span>
                <span class="site-header__nav-label site-header__nav-label--short">Browse</span>
              </a>
              <a class="site-header__nav-link site-header__nav-link--primary" href="/favorites/" data-site-favorites-link hidden>
                Favorites <span data-site-favorites-count></span>
              </a>
            </nav>
            <button
              class="site-header__search"
              type="button"
              data-site-search-open
              data-analytics-event="Open site search"
              aria-haspopup="dialog"
              aria-controls="site-search-panel"
            >
              <FeatureIcon name="search" size={15} />
              <span class="site-header__search-label site-header__search-label--full">Search Routes</span>
              <span class="site-header__search-label site-header__search-label--short">Search</span>
            </button>
            <a class="site-header__action" href="/request-river/" data-analytics-event="Open route request">
              <span class="site-header__action-label site-header__action-label--full">Request</span>
              <span class="site-header__action-label site-header__action-label--short">Request</span>
            </a>
          </div>
          <p class="site-header__blurb">
            Live score, water level, and weather.
          </p>
          <p class="site-header__freshness" data-home-freshness-wrap hidden>
            <span class="site-header__freshness-item">Data refreshes every 30 minutes.</span>
            <span class="site-header__freshness-item site-header__freshness-item--updated" data-home-freshness>Checking latest refresh...</span>
          </p>
        </div>
      </header>

      <main class="main-shell">
        <slot />
      </main>

      <footer class="site-footer">
        <nav class="site-footer__nav" aria-label="Footer">
          <a class="site-footer__link" href="/about/">About</a>
          <a class="site-footer__link" href="/guides/best-minnesota-paddle-trips/">Guides</a>
          <a class="site-footer__link" href="/contact/">Contact</a>
        </nav>
      </footer>

      <section class="site-search-dialog" data-site-search hidden>
        <div class="site-search-dialog__backdrop" data-site-search-close></div>
        <div class="site-search-dialog__panel" id="site-search-panel" role="dialog" aria-modal="true" aria-labelledby="site-search-title">
          <div class="site-search-dialog__head">
            <div class="site-search-dialog__title-wrap">
              <p class="eyebrow">Search</p>
              <h2 class="site-search-dialog__title" id="site-search-title">Find a river or route</h2>
            </div>
            <button class="filter-chip filter-chip--quiet site-search-dialog__dismiss" type="button" data-site-search-dismiss>Close</button>
          </div>

          <label class="site-search-dialog__field">
            <span class="sr-only">Search routes</span>
            <input
              class="site-search-dialog__input"
              type="search"
              placeholder="Search a river, route, town, or area"
              data-site-search-input
              autocomplete="off"
            />
          </label>

          <p class="muted site-search-dialog__hint" data-site-search-hint>Try Snake, Root, Faribault, or Pine City.</p>
          <div class="site-search-dialog__results" data-site-search-results aria-live="polite"></div>
        </div>
      </section>
    </div>
    <script type="application/json" data-site-search-index set:html={searchIndexJson}></script>
    <script>
      import '../scripts/site-shell.js';
      import '../scripts/analytics.js';
    </script>
  </body>
</html>
