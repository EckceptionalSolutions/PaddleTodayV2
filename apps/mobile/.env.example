# Local API for simulator, Expo Go, and web development.
EXPO_PUBLIC_API_BASE_URL=http://127.0.0.1:4323

# Store and internal EAS builds use the production API through apps/mobile/eas.json.
# EXPO_PUBLIC_API_BASE_URL=https://paddletoday.com

# Optional release observability. Leave empty locally unless testing Sentry.
# EXPO_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# EXPO_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0
# EXPO_PUBLIC_APP_ENV=development
