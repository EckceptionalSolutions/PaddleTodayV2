{
  "expo": {
    "name": "PaddleToday",
    "slug": "paddletoday-mobile",
    "version": "1.0.7",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "paddletoday",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#f4f1e8"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.paddletoday.mobile",
      "appStoreUrl": "https://apps.apple.com/app/id6769542734",
      "buildNumber": "22",
      "infoPlist": {
        "NSUserNotificationsUsageDescription": "PaddleToday can send route alerts when a saved river reaches your chosen paddling threshold.",
        "NSPhotoLibraryUsageDescription": "PaddleToday lets you attach route photos when you choose to submit paddling reports.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#f4f1e8"
      },
      "edgeToEdgeEnabled": true,
      "softwareKeyboardLayoutMode": "resize",
      "predictiveBackGestureEnabled": false,
      "package": "com.paddletoday.mobile",
      "playStoreUrl": "https://play.google.com/store/apps/details?id=com.paddletoday.mobile",
      "versionCode": 15,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "PaddleToday uses your location to highlight nearby paddling options."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "PaddleToday lets you attach route photos when you choose to submit paddling reports."
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static",
            "forceStaticLinking": [
              "RNFBApp",
              "RNFBAnalytics",
              "RNFBCrashlytics"
            ]
          }
        }
      ],
      "./plugins/with-rnfirebase-ios-privacy",
      "expo-notifications"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "f9349f7d-e977-4210-b6b4-e95029226ede"
      }
    },
    "owner": "eckceptionalsolutions"
  }
}
